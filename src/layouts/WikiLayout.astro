---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  section?: string;
  relatedPages?: Array<{ label: string; href: string }>;
}

const { title, description = 'The definitive wiki for James Hwang — artist, actor, auteur.', section, relatedPages } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  { group: 'Artist' },
  { label: 'Overview',           href: `${base}`,                   icon: '◈' },
  { label: 'Biography',          href: `${base}biography`,          icon: '◎' },
  { label: 'Personal Life',      href: `${base}personal-life`,      icon: '◎' },
  { label: 'Timeline',           href: `${base}timeline`,           icon: '◷' },
  { group: 'Music' },
  { label: 'Discography',        href: `${base}discography`,        icon: '◉' },
  { label: 'Music Videos',       href: `${base}music-videos`,       icon: '▶' },
  { label: 'Tours',              href: `${base}tours`,              icon: '◆' },
  { label: 'Collaborations',     href: `${base}collaborations`,     icon: '♫' },
  { label: 'Production Credits', href: `${base}production-credits`, icon: '◎' },
  { group: 'Film' },
  { label: 'Filmography',        href: `${base}filmography`,        icon: '▷' },
  { group: 'Business' },
  { label: 'Company',            href: `${base}company`,            icon: '◇' },
  { label: 'Endorsements',       href: `${base}ecosystem`,          icon: '◐' },
  { label: 'Legal',              href: `${base}legal`,              icon: '⚖' },
  { group: 'Image' },
  { label: 'Public Image',       href: `${base}public-image`,       icon: '◑' },
  { label: 'Fashion & Style',    href: `${base}fashion`,            icon: '◇' },
  { label: 'Awards',             href: `${base}awards`,             icon: '★' },
  { label: 'Interviews & Quotes',href: `${base}interviews`,         icon: '◎' },
  { label: 'Cultural Impact',    href: `${base}cultural-impact`,    icon: '◑' },
  { group: 'Community' },
  { label: 'Canon',              href: `${base}canon`,              icon: '◈' },
  { label: 'Fandom',             href: `${base}fandom`,             icon: '♡' },
  { label: 'Controversies',      href: `${base}controversies`,      icon: '◈' },
  { label: 'Rivalries & Tensions', href: `${base}rivalries`,        icon: '⚔' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — JamesHwangVerse</title>
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const t = localStorage.getItem('theme');
        if (t === 'light') document.documentElement.classList.add('light');
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col" style="background-color:var(--bg)">

    <!-- Top bar -->
    <header class="border-b sticky top-0 z-50" style="background-color:var(--bg-header);border-color:var(--border)">
      <div class="max-w-screen-2xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href={base} class="flex items-center gap-3 group">
          <span class="text-xl font-bold tracking-tight" style="color:var(--gold)">JH</span>
          <span class="text-sm font-semibold transition-colors" style="color:var(--text)">JamesHwangVerse</span>
        </a>
        <div class="flex items-center gap-2">
          <!-- Dark/Light toggle -->
          <button id="theme-toggle" aria-label="Toggle theme" class="p-2 rounded-md transition-colors" style="color:var(--text-muted)">
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
            </svg>
          </button>
          <!-- Mobile menu button -->
          <button id="menu-toggle" class="md:hidden p-2 transition-colors" style="color:var(--text-muted)">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="flex flex-1 max-w-screen-2xl mx-auto w-full">
      <!-- Sidebar -->
      <aside id="sidebar" class="hidden md:flex flex-col w-56 shrink-0 border-r py-6 px-3 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto" style="border-color:var(--border)">
        {section && <p class="text-xs font-semibold uppercase tracking-widest mb-3 px-2" style="color:var(--gold)">{section}</p>}
        <nav class="flex flex-col gap-0.5">
          {nav.map(item => {
            if ('group' in item) {
              return (
                <p class="text-xs font-semibold uppercase tracking-widest px-2 pt-4 pb-1 first:pt-0" style="color:var(--text-faint)">{item.group}</p>
              );
            }
            const isActive = currentPath === item.href || currentPath === item.href + '/';
            return (
              <a
                href={item.href}
                class={`flex items-center gap-2.5 px-2 py-2 rounded-md text-sm transition-colors sidebar-link ${isActive ? 'font-medium sidebar-active' : 'sidebar-inactive'}`}
                style={isActive ? 'color:var(--gold);background-color:var(--bg-muted)' : 'color:var(--text-muted)'}
              >
                <span class="text-xs w-3.5 shrink-0 opacity-70">{item.icon}</span>
                {item.label}
              </a>
            );
          })}
        </nav>
      </aside>

      <!-- Mobile sidebar overlay -->
      <div id="mobile-sidebar" class="fixed inset-0 z-40 hidden md:hidden">
        <div id="sidebar-backdrop" class="absolute inset-0 bg-black/70"></div>
        <nav class="absolute left-0 top-14 bottom-0 w-64 border-r py-6 px-3 overflow-y-auto" style="background-color:var(--bg);border-color:var(--border)">
          {nav.map(item => {
            if ('group' in item) {
              return (
                <p class="text-xs font-semibold uppercase tracking-widest px-2 pt-4 pb-1 first:pt-0" style="color:var(--text-faint)">{item.group}</p>
              );
            }
            const isActive = currentPath === item.href || currentPath === item.href + '/';
            return (
              <a
                href={item.href}
                class={`flex items-center gap-2.5 px-2 py-2 rounded-md text-sm mb-0.5 transition-colors sidebar-link ${isActive ? 'font-medium sidebar-active' : 'sidebar-inactive'}`}
                style={isActive ? 'color:var(--gold);background-color:var(--bg-muted)' : 'color:var(--text-muted)'}
              >
                <span class="text-xs w-3.5 shrink-0 opacity-70">{item.icon}</span>
                {item.label}
              </a>
            );
          })}
        </nav>
      </div>

      <!-- Main content -->
      <main id="wiki-main" class="flex-1 min-w-0 px-6 md:px-8 py-8">

        <!-- Mobile TOC toggle (injected by JS when headings exist, hidden on xl where sidebar shows) -->
        <div id="mobile-toc-container" class="hidden xl:hidden mb-6">
          <button id="mobile-toc-toggle" class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest px-3 py-2 rounded-md border w-full" style="color:var(--text-muted);border-color:var(--border);background:var(--bg-surface)">
            <span style="color:var(--gold)">≡</span>
            <span>Contents</span>
            <span id="mobile-toc-count" class="text-xs px-1.5 py-0.5 rounded font-bold ml-1" style="background:color-mix(in srgb,var(--gold) 12%,transparent);color:var(--gold)"></span>
            <span id="mobile-toc-arrow" class="ml-auto transition-transform duration-200">▾</span>
          </button>
          <nav id="mobile-toc-list" class="hidden mt-1 rounded-md border overflow-y-auto" style="border-color:var(--border);background:var(--bg-surface);max-height:60vh">
          </nav>
        </div>

        <slot />
      </main>

      <!-- Right TOC sidebar (xl+) -->
      <aside id="toc-sidebar" class="hidden xl:flex flex-col w-48 shrink-0 border-l sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto py-6 px-3" style="border-color:var(--border)">
        <p id="toc-heading" class="hidden text-xs font-semibold uppercase tracking-widest mb-3 px-1" style="color:var(--gold)">Contents</p>
        <nav id="toc-list" class="flex flex-col gap-0.5 text-xs"></nav>

        {relatedPages && relatedPages.length > 0 && (
          <div id="toc-related" class="mt-6 pt-5 border-t" style="border-color:var(--border)">
            <p class="text-xs font-semibold uppercase tracking-widest mb-2 px-1" style="color:var(--gold)">See Also</p>
            <nav class="flex flex-col gap-0.5">
              {relatedPages.map(p => (
                <a href={p.href} class="toc-related-link px-1 py-1 rounded text-xs transition-colors" style="color:var(--text-muted)">
                  {p.label}
                </a>
              ))}
            </nav>
          </div>
        )}
      </aside>
    </div>

    <footer class="border-t mt-auto py-6 text-center text-xs" style="border-color:var(--border);color:var(--text-faint)">
      JamesHwangVerse — Fictional universe. All events, persons, and works are fictional.
    </footer>


    <script>
      // TOC generation
      (function() {
        const main = document.getElementById('wiki-main');
        if (!main) return;

        const headings = Array.from(main.querySelectorAll('h2, h3')) as HTMLElement[];
        if (headings.length < 2) return;

        // Assign IDs to headings that lack them
        const seen: Record<string, number> = {};
        headings.forEach(h => {
          if (!h.id) {
            const raw = h.textContent?.trim().toLowerCase()
              .replace(/[^\w\s\u0E00-\u0E7F-]/g, '')
              .replace(/\s+/g, '-') ?? 'section';
            const key = raw.slice(0, 40) || 'section';
            seen[key] = (seen[key] ?? 0) + 1;
            h.id = seen[key] > 1 ? `${key}-${seen[key]}` : key;
          }
        });

        // Build desktop TOC
        const tocList = document.getElementById('toc-list');
        const tocHeading = document.getElementById('toc-heading');
        if (tocList && tocHeading) {
          tocHeading.classList.remove('hidden');
          headings.forEach(h => {
            const a = document.createElement('a');
            a.href = `#${h.id}`;
            a.textContent = h.textContent?.trim() ?? '';
            a.className = 'toc-item' + (h.tagName === 'H3' ? ' toc-h3' : '');
            a.dataset.id = h.id;
            tocList.appendChild(a);
          });
        }

        // Build mobile TOC
        const mobileContainer = document.getElementById('mobile-toc-container');
        const mobileList = document.getElementById('mobile-toc-list');
        const mobileToggle = document.getElementById('mobile-toc-toggle');
        const mobileArrow = document.getElementById('mobile-toc-arrow');
        const mobileCount = document.getElementById('mobile-toc-count');
        if (mobileContainer && mobileList) {
          // Only show on non-xl viewports (xl has the sidebar)
          if (window.innerWidth < 1280) mobileContainer.classList.remove('hidden');
          window.addEventListener('resize', () => {
            mobileContainer.classList.toggle('hidden', window.innerWidth >= 1280);
          });

          const h2Items = headings.filter(h => h.tagName === 'H2');
          if (mobileCount) mobileCount.textContent = String(h2Items.length || headings.length);

          let h2idx = 0;
          headings.forEach(h => {
            const isH2 = h.tagName === 'H2';
            if (isH2) h2idx++;

            const a = document.createElement('a');
            a.href = `#${h.id}`;
            a.className = 'mobile-toc-item' + (isH2 ? '' : ' toc-h3');

            if (isH2) {
              const num = document.createElement('span');
              num.className = 'toc-item-num';
              num.textContent = String(h2idx);
              a.appendChild(num);
            }

            const txt = document.createElement('span');
            txt.className = 'toc-item-text';
            txt.textContent = h.textContent?.trim() ?? '';
            a.appendChild(txt);

            a.addEventListener('click', () => {
              mobileList.classList.add('hidden');
              if (mobileArrow) mobileArrow.style.transform = '';
            });
            mobileList.appendChild(a);
          });

          mobileToggle?.addEventListener('click', () => {
            const hidden = mobileList.classList.toggle('hidden');
            if (mobileArrow) mobileArrow.style.transform = hidden ? '' : 'rotate(180deg)';
          });
        }

        // IntersectionObserver — highlight active section in desktop TOC
        if (!tocList) return;
        const tocLinks = tocList.querySelectorAll<HTMLAnchorElement>('.toc-item');
        let activeId = '';
        const observer = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              activeId = entry.target.id;
            }
          });
          tocLinks.forEach(a => {
            a.classList.toggle('toc-active', a.dataset.id === activeId);
          });
        }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });

        headings.forEach(h => observer.observe(h));
      })();
    </script>

    <script>
      // Mobile menu
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('mobile-sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      toggle?.addEventListener('click', () => sidebar?.classList.toggle('hidden'));
      backdrop?.addEventListener('click', () => sidebar?.classList.add('hidden'));

      // Theme toggle
      const themeToggle = document.getElementById('theme-toggle');
      const iconMoon = document.getElementById('icon-moon');
      const iconSun = document.getElementById('icon-sun');

      function applyTheme(theme: string) {
        if (theme === 'light') {
          document.documentElement.classList.add('light');
          iconMoon?.classList.add('hidden');
          iconSun?.classList.remove('hidden');
        } else {
          document.documentElement.classList.remove('light');
          iconMoon?.classList.remove('hidden');
          iconSun?.classList.add('hidden');
        }
      }

      const saved = localStorage.getItem('theme') ?? 'dark';
      applyTheme(saved);

      themeToggle?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.contains('light');
        const next = isLight ? 'dark' : 'light';
        localStorage.setItem('theme', next);
        applyTheme(next);
      });
    </script>
  </body>
</html>
