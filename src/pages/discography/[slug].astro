    title: 'LIKE I DO',
    subtitle: 'GONUNMA · Mini Album',
    year: '2016',
    color: '#c9a84c',
  },
  'softest-touch': {
    file: '03-softest-touch',
    title: 'SOFTEST TOUCH',
    subtitle: '1st Mini Album',
    year: '2022',
    color: '#9b7fc8',
  },
  'pulse-era': {
    file: '04-pulse-era',
    title: 'PULSE',
    subtitle: '1st Studio Album',
    year: '2023',
    color: '#5a7c6a',
  },
  'are-u-still': {
