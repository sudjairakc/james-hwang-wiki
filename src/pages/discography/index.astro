---
import WikiLayout from '../../layouts/WikiLayout.astro';

const base = import.meta.env.BASE_URL;

const albums = [
  {
    slug: 'like-i-do',
    title: 'LIKE I DO',
    subtitle: 'GONUNMA',
    year: '2016',
    date: 'Nov 11, 2016',
    type: 'Mini Album',
    label: 'SM Entertainment',
    tracks: 7,
    streams: 210,
    streamLabel: '210M+',
    peak: 'Top 40 (resurgence 2022)',
    era: 'SM Era',
    color: '#c9a84c',
    highlight: 'Creative blueprint · GONUNMA alter ego debut · TikTok resurgence 2023–24',
    titleTrack: 'LIKE I DO (feat. Mark Lee)',
    genres: ['R&B', 'Pop'],
  },
  {
    slug: 'softest-touch',
    title: 'SOFTEST TOUCH',
    subtitle: '1st Mini Album',
    year: '2022',
    date: 'Jan 11, 2022',
    type: '1st Mini Album',
    label: 'SM Entertainment',
    tracks: 7,
    streams: 320,
    streamLabel: '320M+',
    peak: 'Melon #18 · Circle Top 5',
    era: 'SM Solo',
    color: '#9b7fc8',
    highlight: 'Official songwriter-led solo identity · SM era debut',
    titleTrack: 'SOFTEST TOUCH',
    genres: ['R&B', 'Pop', 'Indie'],
  },
  {
    slug: 'pulse-era',
    title: 'PULSE',
    subtitle: '1st Studio Album',
    year: '2023',
    date: 'Jul 21, 2023',
    type: '1st Studio Album',
    label: 'JH Company / Warner Music Korea',
    tracks: 10,
    streams: 540,
    streamLabel: '540M+',
    peak: 'Melon #7 · Circle Top 15',
    era: 'Independent',
    color: '#5a7c6a',
    highlight: 'First independent release · Global R&B breakout · SAY feat. keshi 210M+',
    titleTrack: 'HOW DOES IT FEEL',
    genres: ['R&B', 'Pop', 'Synth Funk', 'Nu-Disco'],
  },
  {
    slug: 'are-u-still',
    title: 'ARE U STILL',
    subtitle: '2nd Studio Album',
    year: '2024',
    date: 'Jan 8, 2024',
    type: '2nd Studio Album',
    label: 'JH Company / Warner Music Korea',
    tracks: 11,
    streams: 820,
    streamLabel: '820M+',
    peak: 'Melon #2 · Circle Top 5',
    era: 'Grammy Era',
    color: '#5a7aaa',
    highlight: 'Grammy wins: Best Progressive R&B + Best R&B Performance · Neo-soul pivot',
    titleTrack: 'TEARS ON A PRETTY FACE',
    genres: ['Neo-Soul', 'R&B', 'Alternative R&B', 'Funk', 'Soul'],
  },
  {
    slug: 'sour-honey',
    title: 'SOUR | HONEY',
    subtitle: '3rd Studio Album',
    year: '2025',
    date: 'Feb 10, 2025',
    type: '3rd Studio Album',
    label: 'JH Company / Warner Music Korea',
    tracks: 11,
    streams: 640,
    streamLabel: '640M+',
    peak: 'Melon #8 · Circle Top 20',
    era: 'Post-Grammy',
    color: '#c06080',
    highlight: "Duality concept · CAN'T LEAVE ALONE feat. Pharrell Williams 260M+",
    titleTrack: 'SOUR',
    genres: ['R&B', 'Contemporary R&B', 'Soul'],
  },
  {
    slug: 'decade',
    title: 'DECADE',
    subtitle: 'Anthology',
    year: '2026',
    date: 'Sep 9, 2026',
    type: 'Anthology Album',
    label: 'JH Company / Warner Music Korea',
    tracks: 25,
    streams: 480,
    streamLabel: '480M+',
    peak: 'Melon #9 · US R&B Top 20',
    era: 'Legacy',
    color: '#6e5a7c',
    highlight: '10-year retrospective · Extended arrangements · 32M monthly Spotify listeners',
    titleTrack: 'NEW',
    genres: ['Multi-era', 'R&B', 'Soul'],
  },
];

const maxStreams = Math.max(...albums.map(a => a.streams));
const totalStreams = albums.reduce((s, a) => s + a.streams, 0);
---

<WikiLayout title="Discography" section="Music" relatedPages={[
  { label: 'Awards', href: `${base}awards` },
  { label: 'Tours', href: `${base}tours` },
  { label: 'Career Timeline', href: `${base}timeline` },
  { label: 'Cultural Impact', href: `${base}cultural-impact` },
  { label: 'JH Company', href: `${base}company` },
]}>
  <div class="mb-8">
    <div class="wiki-label mb-2">Music</div>
    <h1 class="wiki-title mb-2">Discography</h1>
    <p class="text-sm" style="color:var(--text-muted)">6 projects · 2016–2026 · {(totalStreams / 1000).toFixed(1)}B+ cumulative streams</p>
  </div>

  <!-- Era timeline -->
  <div class="mb-10">
    <div class="flex items-stretch gap-0 rounded-lg overflow-hidden h-10">
      {albums.map(a => (
        <a href={`${base}discography/${a.slug}`}
          class="flex-1 flex items-center justify-center group relative transition-all hover:flex-[1.5]"
          style={`background-color:${a.color}30;border-right:1px solid var(--bg);`}
          title={`${a.title} · ${a.year}`}>
          <span class="text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity absolute whitespace-nowrap px-2" style={`color:${a.color}`}>{a.title}</span>
          <div class="w-full h-1 absolute bottom-0" style={`background-color:${a.color}`}></div>
        </a>
      ))}
    </div>
    <div class="flex mt-1">
      {albums.map(a => (
        <div class="flex-1 text-center">
          <div class="text-xs font-mono" style={`color:${a.color};font-size:0.6rem`}>{a.year}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Stream comparison -->
  <section class="mb-10">
    <div class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:var(--gold)">Streams by Era</div>
    <div class="flex flex-col gap-2">
      {albums.map(a => (
        <a href={`${base}discography/${a.slug}`} class="flex items-center gap-3 group">
          <div class="w-24 text-xs font-bold text-right shrink-0 group-hover:underline" style={`color:${a.color}`}>{a.title}</div>
          <div class="flex-1 h-5 rounded overflow-hidden" style="background-color:var(--bg-muted)">
            <div class="h-full rounded transition-all" style={`width:${(a.streams / maxStreams) * 100}%;background-color:${a.color};opacity:0.7`}></div>
          </div>
          <div class="text-sm font-bold w-14 shrink-0" style={`color:${a.color}`}>{a.streamLabel}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Album list -->
  <div class="flex flex-col gap-3 mb-8">
    {albums.map((a, i) => (
      <a href={`${base}discography/${a.slug}`}
        class="flex gap-4 border rounded-xl p-5 transition-all group"
        style="border-color:var(--border);background-color:var(--bg-surface);text-decoration:none">

        <!-- Color slab -->
        <div class="w-16 h-16 shrink-0 rounded-xl flex items-center justify-center text-2xl font-black relative overflow-hidden"
          style={`background-color:${a.color}20`}>
          <div class="absolute inset-y-0 left-0 w-1" style={`background-color:${a.color}`}></div>
          <span style={`color:${a.color}`}>{i + 1}</span>
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-baseline gap-2 mb-0.5">
            <h2 id={a.slug} class="text-base font-black m-0 group-hover:underline" style={`color:var(--text);text-decoration-color:${a.color}`}>{a.title}</h2>
            <span class="text-xs" style="color:var(--text-muted)">{a.subtitle}</span>
            <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style={`background-color:${a.color}18;color:${a.color}`}>{a.era}</span>
          </div>
          <div class="text-xs mb-1.5" style="color:var(--text-muted)">{a.date} · {a.type} · {a.tracks} tracks · {a.label}</div>
          <div class="flex flex-wrap gap-1.5 mb-1.5">
            {a.genres.map(g => (
              <span class="text-xs px-1.5 py-0.5 rounded border" style="border-color:var(--border);color:var(--text-muted)">{g}</span>
            ))}
          </div>
          <p class="text-xs leading-relaxed" style="color:var(--text-muted)">{a.highlight}</p>
        </div>

        <!-- Metrics -->
        <div class="hidden md:flex flex-col items-end shrink-0 gap-2 justify-between">
          <div class="text-right">
            <div class="text-xl font-black">{a.streamLabel}</div>
            <div class="text-xs" style="color:var(--text-muted)">streams</div>
          </div>
          <div class="text-right">
            <div class="text-xs font-semibold">{a.titleTrack}</div>
            <div class="text-xs" style="color:var(--text-muted)">title track</div>
          </div>
          <div class="text-right">
            <div class="text-xs" style={`color:${a.color}`}>{a.peak}</div>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Singles -->
  <div class="rounded-xl border overflow-hidden" style="border-color:var(--border)">
    <div class="px-5 py-3 border-b text-xs font-semibold uppercase tracking-widest" style="border-color:var(--border);background-color:var(--bg-surface);color:var(--gold)">Singles & Station Releases</div>
    <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x" style="divide-color:var(--border);background-color:var(--bg-surface)">
      {[
        { title: "YOU AIN'T GOTTA", sub: 'SM STATION 2', year: '2018', streams: 'Spotify 55M+', note: 'R&B positioning reinforcement' },
        { title: 'CRUSH feat. Jungkook', sub: 'SM STATION 3', year: '2019', streams: 'Spotify 260M+', note: 'First major international crossover' },
        { title: 'IF I KNEW', sub: 'PULSE era single', year: '2023', streams: 'Spotify 47M+', note: 'Pre-release bridge to 2nd album' },
      ].map(s => (
        <div class="px-5 py-4">
          <div class="text-sm font-bold mb-0.5">{s.title}</div>
          <div class="text-xs mb-1" style="color:var(--text-muted)">{s.sub} · {s.year}</div>
          <div class="text-xs font-semibold mb-1" style="color:var(--gold)">{s.streams}</div>
          <div class="text-xs" style="color:var(--text-muted)">{s.note}</div>
        </div>
      ))}
    </div>
  </div>
</WikiLayout>
