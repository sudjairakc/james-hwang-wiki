---
import WikiLayout from '../layouts/WikiLayout.astro';
import { Content } from '../content/wiki/public-image.md';
---
<WikiLayout title="Public Image" section="Biography">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Biography</div>
    <h1 class="text-4xl font-bold text-white mb-2">Public Image & Personal Background</h1>
    <p class="text-gray-400 text-sm">Half-Thai, Half-Korean · Born June 22, 1998 · Thai citizenship</p>
  </div>
  <div class="prose prose-invert max-w-none"><Content /></div>
</WikiLayout>
