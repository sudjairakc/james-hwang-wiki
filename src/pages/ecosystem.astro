---
import WikiLayout from '../layouts/WikiLayout.astro';
import { Content } from '../content/wiki/ecosystem.md';
import { Content as TouringContent } from '../content/wiki/ecosystem/touring_ecosystem.md';

const deals = [
  { brand: 'Saint Laurent', value: '$4–7M/yr', category: 'Fashion' },
  { brand: 'Cartier', value: '$2–4M/yr', category: 'Luxury' },
  { brand: 'Sony', value: '$3–5M/yr', category: 'Electronics' },
  { brand: 'Nike', value: '$1.5–3M/yr', category: 'Sports' },
  { brand: 'Dior Beauty', value: '$1–2M/yr', category: 'Beauty' },
];
---
<WikiLayout title="Endorsements" section="Business">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Business</div>
    <h1 class="text-4xl font-bold text-white mb-2">Endorsements & Brand Deals</h1>
    <p class="text-gray-400 text-sm">$16M–22M/yr total · Solo + group contracts</p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-10">
    {deals.map(d => (
      <div class="border rounded-lg p-4 text-center" style="border-color:#2a2a2a;background-color:#141414">
        <div class="text-xs text-gray-600 mb-1">{d.category}</div>
        <div class="text-sm font-semibold text-white mb-1">{d.brand}</div>
        <div class="text-xs" style="color:#c9a84c">{d.value}</div>
      </div>
    ))}
  </div>

  <div class="prose prose-invert max-w-none"><Content /></div>

  <div class="border-t mt-10 pt-10" style="border-color:#2a2a2a">
    <h2 class="text-2xl font-bold text-white mb-6">Touring Economy</h2>
    <div class="prose prose-invert max-w-none"><TouringContent /></div>
  </div>
</WikiLayout>
