---
import WikiLayout from '../layouts/WikiLayout.astro';
// @ts-ignore
import rawContent from '../content/wiki/timeline.md?raw';

// ── Parser ────────────────────────────────────────────────────────────────────
interface Event { text: string; subs: string[] }
interface Month { label: string; shortLabel: string; events: Event[] }
interface YearEntry { year: string; era: string; eraSlug: string; age: string; months: Month[] }

function eraSlugOf(era: string) {
  if (era.includes('PRE DEBUT'))   return 'pre-debut';
  if (era.includes('ROOKIES'))     return 'rookies';
  if (era.includes('NCT 127'))     return 'nct127';
  if (era.includes('SHANG-CHI'))   return 'shangchi';
  if (era.includes('SOLO'))        return 'solo';
  return 'other';
}

function monthName(shortLabel: string) {
  const map: Record<string, string> = {
    '01': 'ม.ค.', '02': 'ก.พ.', '03': 'มี.ค.', '04': 'เม.ย.',
    '05': 'พ.ค.', '06': 'มิ.ย.', '07': 'ก.ค.', '08': 'ส.ค.',
    '09': 'ก.ย.', '10': 'ต.ค.', '11': 'พ.ย.', '12': 'ธ.ค.',
  };
  // Handle ranges like "08–09" → "ส.ค.–ก.ย."
  const rangeMatch = shortLabel.match(/^(\d{2})[–\-](\d{2})$/);
  if (rangeMatch) {
    return (map[rangeMatch[1]] || rangeMatch[1]) + '–' + (map[rangeMatch[2]] || rangeMatch[2]);
  }
  return map[shortLabel] || shortLabel;
}

function parseTimeline(raw: string): YearEntry[] {
  const lines = raw.split('\n');
  let currentEra = 'PRE DEBUT ERA';
  let currentYear: YearEntry | null = null;
  let currentMonth: Month | null = null;
  const years: YearEntry[] = [];

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;

    // Era header — all-caps line containing "ERA"
    if (/ERA/.test(trimmed) && /^[A-Za-zА-Яа-я0-9\s\(\)\-–]+$/.test(trimmed)) {
      currentEra = trimmed;
      continue;
    }

    // Year header: "2013 (อายุ 15 ปี)" or "2024 (26 Years old)"
    const yearMatch = trimmed.match(/^(\d{4})\s*\((.+?)\)\s*$/);
    if (yearMatch) {
      currentYear = {
        year: yearMatch[1],
        era: currentEra,
        eraSlug: eraSlugOf(currentEra),
        age: yearMatch[2].trim(),
        months: [],
      };
      currentMonth = null;
      years.push(currentYear);
      continue;
    }

    // Month header: "01/2023" or "08–09/2023" or "05–06/2023"
    const monthMatch = trimmed.match(/^(\d{1,2}(?:[–\-]\d{1,2})?)\/(\d{4})$/);
    if (monthMatch && currentYear) {
      currentMonth = {
        label: trimmed,
        shortLabel: monthName(monthMatch[1]),
        events: [],
      };
      currentYear.months.push(currentMonth);
      continue;
    }

    // Sub-bullet (indented ≥ 4 spaces + *)
    if (/^\s{4,}\*/.test(line) && currentYear) {
      const text = trimmed.replace(/^\*\s*/, '');
      const target = currentMonth ? currentMonth.events : null;
      if (target && target.length > 0) {
        target[target.length - 1].subs.push(text);
      }
      continue;
    }

    // Top-level bullet
    if (trimmed.startsWith('*') && currentYear) {
      const text = trimmed.replace(/^\*\s*/, '');
      const event: Event = { text, subs: [] };
      if (currentMonth) {
        currentMonth.events.push(event);
      } else {
        // No month header yet — create implicit "ทั้งปี" group lazily
        if (currentYear.months.length === 0 || currentYear.months[0].shortLabel !== 'ทั้งปี') {
          currentMonth = { label: currentYear.year, shortLabel: 'ทั้งปี', events: [] };
          currentYear.months.unshift(currentMonth);
        } else {
          currentMonth = currentYear.months[0];
        }
        currentMonth.events.push(event);
      }
      continue;
    }
  }

  return years;
}

const years = parseTimeline(rawContent);

// Deduplicate era list in order
const erasOrdered: string[] = [];
for (const y of years) {
  if (!erasOrdered.includes(y.era)) erasOrdered.push(y.era);
}

// Serialise to JSON for client-side JS
const yearsJSON = JSON.stringify(years);
---

<WikiLayout title="Career Timeline" section="Biography">

  <!-- Page header -->
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Biography</div>
    <h1 class="text-4xl font-bold text-white mb-2">Career Timeline</h1>
    <p class="text-gray-400 text-sm">1998–present · SM Rookies → NCT 127 → Independent artist</p>
  </div>

  <!-- Era filter pills -->
  <div class="flex flex-wrap gap-2 mb-8" id="era-filters">
    <button
      data-era="all"
      class="era-pill px-3 py-1 rounded-full text-xs font-semibold border transition-all active-pill"
      style="border-color:#c9a84c;color:#c9a84c;background:#1e1e1e"
    >ทั้งหมด</button>
    {erasOrdered.map(era => (
      <button
        data-era={eraSlugOf(era)}
        class="era-pill px-3 py-1 rounded-full text-xs font-semibold border transition-all"
        style="border-color:#3a3a3a;color:#888"
      >{era.replace(/\s*\(.*\)/, '')}</button>
    ))}
  </div>

  <!-- Year grid -->
  <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3 mb-10" id="year-grid">
    {years.map(y => (
      <button
        data-year={y.year}
        data-era={y.eraSlug}
        class="year-card group relative flex flex-col items-center justify-center rounded-xl border p-3 transition-all cursor-pointer text-center"
        style="border-color:#2a2a2a;background:#111"
      >
        <span class="year-num text-xl font-bold text-white group-hover:text-yellow-400 transition-colors" style="">{y.year}</span>
        <span class="text-xs mt-0.5 truncate max-w-full" style="color:#666">{y.age}</span>
        <span class={`era-dot mt-1.5 w-1.5 h-1.5 rounded-full era-dot-${y.eraSlug}`}></span>
      </button>
    ))}
  </div>

  <!-- Detail panel (hidden until year selected) -->
  <div id="detail-panel" class="hidden">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-5 text-sm text-gray-500">
      <button id="back-btn" class="hover:text-white transition-colors flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        ย้อนกลับ
      </button>
      <span>/</span>
      <span id="breadcrumb-year" class="font-semibold text-white"></span>
      <span id="breadcrumb-era" class="text-xs px-2 py-0.5 rounded-full" style="background:#1e1e1e;color:#888"></span>
    </div>

    <!-- Month buttons -->
    <div id="month-buttons" class="flex flex-wrap gap-2 mb-6"></div>

    <!-- Events -->
    <div id="events-container" class="border rounded-xl p-5 min-h-32" style="border-color:#2a2a2a;background:#111">
      <p class="text-gray-500 text-sm">เลือกเดือนเพื่อดูเหตุการณ์</p>
    </div>

  </div>

</WikiLayout>

<style>
  /* Era dot colours */
  .era-dot-pre-debut  { background: #555; }
  .era-dot-rookies    { background: #3b82f6; }
  .era-dot-nct127     { background: #ef4444; }
  .era-dot-shangchi   { background: #a855f7; }
  .era-dot-solo       { background: #c9a84c; }
  .era-dot-other      { background: #888; }

  /* Year card active state */
  .year-card.selected {
    border-color: #c9a84c !important;
    background: #1a1500 !important;
  }
  .year-card.selected .year-num {
    color: #c9a84c !important;
  }

  /* Month pill active */
  .month-btn.active {
    background: #c9a84c !important;
    color: #000 !important;
    border-color: #c9a84c !important;
  }

  /* Era pill active */
  .era-pill.active-pill {
    border-color: #c9a84c !important;
    color: #c9a84c !important;
    background: #1e1e1e !important;
  }

  /* Fade hidden */
  .year-card.era-hidden { display: none; }

  /* Event list */
  .event-item { border-left: 2px solid #2a2a2a; }
  .event-item:hover { border-left-color: #c9a84c; }
</style>

<script is:inline define:vars={{ yearsJSON }}>
  const years = JSON.parse(yearsJSON);

  const yearGrid     = document.getElementById('year-grid');
  const detailPanel  = document.getElementById('detail-panel');
  const backBtn      = document.getElementById('back-btn');
  const monthButtons = document.getElementById('month-buttons');
  const eventsContainer = document.getElementById('events-container');
  const breadcrumbYear  = document.getElementById('breadcrumb-year');
  const breadcrumbEra   = document.getElementById('breadcrumb-era');
  const eraFilters   = document.getElementById('era-filters');

  let activeYear = null;

  // ── Era filter ────────────────────────────────────────────────────────────
  eraFilters?.addEventListener('click', (e) => {
    const btn = e.target.closest('.era-pill');
    if (!btn) return;
    const era = btn.dataset.era;

    // Update pill styles
    document.querySelectorAll('.era-pill').forEach(p => {
      p.classList.remove('active-pill');
      p.style.borderColor = '#3a3a3a';
      p.style.color = '#888';
      p.style.background = '';
    });
    btn.classList.add('active-pill');
    btn.style.borderColor = '#c9a84c';
    btn.style.color = '#c9a84c';
    btn.style.background = '#1e1e1e';

    // Filter year cards
    document.querySelectorAll('.year-card').forEach(card => {
      if (era === 'all' || card.dataset.era === era) {
        card.classList.remove('era-hidden');
      } else {
        card.classList.add('era-hidden');
      }
    });

    // Close detail if active year is filtered out
    if (activeYear && era !== 'all' && activeYear.eraSlug !== era) {
      closeDetail();
    }
  });

  // ── Year card click ───────────────────────────────────────────────────────
  yearGrid?.addEventListener('click', (e) => {
    const card = e.target.closest('.year-card');
    if (!card) return;
    const yearStr = card.dataset.year;
    const yearData = years.find(y => y.year === yearStr);
    if (!yearData) return;

    // Deselect previous
    document.querySelectorAll('.year-card.selected').forEach(c => c.classList.remove('selected'));

    // If clicking same year, toggle close
    if (activeYear && activeYear.year === yearStr) {
      closeDetail();
      return;
    }

    card.classList.add('selected');
    openYear(yearData);

    // Scroll detail into view smoothly
    detailPanel?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  function openYear(yearData) {
    activeYear = yearData;

    // Breadcrumb
    breadcrumbYear.textContent = yearData.year + ' — ' + yearData.age;
    breadcrumbEra.textContent  = yearData.era.replace(/\s*\(.*\)/, '');

    // Month buttons
    monthButtons.innerHTML = '';
    yearData.months.forEach((m, idx) => {
      const btn = document.createElement('button');
      btn.className = 'month-btn px-3 py-1.5 rounded-lg border text-sm font-medium transition-all';
      btn.style.cssText = 'border-color:#3a3a3a;color:#aaa;background:#111';
      btn.textContent = m.shortLabel;
      btn.dataset.idx = idx;
      btn.addEventListener('click', () => selectMonth(yearData, m, btn));
      monthButtons.appendChild(btn);
    });

    // Reset events
    eventsContainer.innerHTML = '<p class="text-gray-500 text-sm">เลือกเดือนเพื่อดูเหตุการณ์</p>';

    // Show panel
    detailPanel.classList.remove('hidden');

    // Auto-select if only one month
    if (yearData.months.length === 1) {
      const onlyBtn = monthButtons.querySelector('.month-btn');
      if (onlyBtn) selectMonth(yearData, yearData.months[0], onlyBtn);
    }
  }

  function selectMonth(_yearData, monthData, btn) {

    // Update button styles
    monthButtons.querySelectorAll('.month-btn').forEach(b => {
      b.classList.remove('active');
      b.style.borderColor = '#3a3a3a';
      b.style.color = '#aaa';
      b.style.background = '#111';
    });
    btn.classList.add('active');

    // Render events
    renderEvents(monthData.events);
  }

  function renderEvents(events) {
    if (!events || events.length === 0) {
      eventsContainer.innerHTML = '<p class="text-gray-500 text-sm">ไม่มีข้อมูลในช่วงนี้</p>';
      return;
    }

    const html = events.map(ev => {
      const subs = ev.subs.length
        ? `<ul class="mt-2 space-y-1.5 pl-3 border-l" style="border-color:#333">
            ${ev.subs.map(s => `<li class="text-sm" style="color:#999">${escHtml(s)}</li>`).join('')}
           </ul>`
        : '';
      return `
        <div class="event-item pl-3 py-2 rounded-r transition-colors mb-2">
          <p class="text-sm leading-relaxed" style="color:#d1d5db">${escHtml(ev.text)}</p>
          ${subs}
        </div>`;
    }).join('');

    eventsContainer.innerHTML = html;
  }

  function closeDetail() {
    activeYear = null;
    activeMonth = null;
    detailPanel.classList.add('hidden');
    document.querySelectorAll('.year-card.selected').forEach(c => c.classList.remove('selected'));
  }

  function escHtml(str) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  backBtn?.addEventListener('click', closeDetail);
</script>
