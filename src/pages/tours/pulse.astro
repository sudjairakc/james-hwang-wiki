---
import WikiLayout from '../../layouts/WikiLayout.astro';
import { Content } from '../../content/wiki/tours/pulse.md';
const base = import.meta.env.BASE_URL;
---
<WikiLayout title="PULSE World Tour" section="Tours">
  <a href={`${base}tours`} class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-gray-300 mb-6 transition-colors">← Back to Tours</a>
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#5a7c6a">World Tour</div>
    <h1 class="text-4xl font-bold text-white mb-1">PULSE World Tour</h1>
    <p class="text-gray-400 text-sm">July 2023 – May 2024 · 64 shows · $235M gross</p>
  </div>
  <div class="prose prose-invert max-w-none"><Content /></div>
</WikiLayout>
