---
import WikiLayout from '../../layouts/WikiLayout.astro';
import { Content } from '../../content/wiki/tours/decade.md';
const base = import.meta.env.BASE_URL;
---
<WikiLayout title="DECADE Tour" section="Tours">
  <a href={`${base}tours`} class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-gray-300 mb-6 transition-colors">← Back to Tours</a>
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#6e5a7c">Tour</div>
    <h1 class="text-4xl font-bold text-white mb-1">DECADE Tour</h1>
    <p class="text-gray-400 text-sm">Jan 13 – Feb 28, 2027 · 29 songs · $74M gross</p>
    <p class="text-gray-400 text-sm mt-4 italic">"LIKE I DO, I gave it all,<br />
A SOFTEST TOUCH, before the fall.<br />
Feel my PULSE, it’s running wild,<br />
ARE YOU STILL that same old child?<br />
SOUR turns sweet, then HONEY fades,<br />
A DECADE lives in songs we made."</p>
  </div>
  <div class="prose prose-invert max-w-none"><Content /></div>
</WikiLayout>
