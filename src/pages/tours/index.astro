---
import WikiLayout from '../../layouts/WikiLayout.astro';
const base = import.meta.env.BASE_URL;

const tours = [
  {
    slug: 'pulse',
    name: 'PULSE World Tour',
    tagline: 'Let your PULSE rise, come fly with me',
    period: 'July 2023 – May 2024',
    legs: 5,
    shows: 64,
    songsPerNight: '23–33',
    gross: '$235M',
    color: '#5a7c6a',
    regions: ['East Asia', 'Southeast Asia', 'Americas', 'Europe', 'Rest of World'],
  },
  {
    slug: 'decade',
    name: 'DECADE Tour',
    tagline: 'DECADE lives in songs we made',
    period: 'Jan 13 – Feb 28, 2027',
    legs: null,
    shows: null,
    songsPerNight: '29',
    gross: '$74M',
    color: '#6e5a7c',
    regions: [],
  },
];
---

<WikiLayout title="Tours" section="Live">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Live</div>
    <h1 class="text-4xl font-bold text-white mb-2">Tours</h1>
    <p class="text-gray-400 text-sm">$309M combined gross · 2 world tours</p>
  </div>

  <div class="space-y-4 mb-10">
    {tours.map(t => (
      <a href={`${base}tours/${t.slug}`}
        class="block border rounded-xl p-6 hover:border-gray-500 transition-all group"
        style="border-color:#2a2a2a;background-color:#141414">
        <div class="flex flex-col md:flex-row md:items-start gap-4">
          <div class="flex-1">
            <div class="text-xs font-semibold uppercase tracking-widest mb-1" style={`color:${t.color}`}>World Tour</div>
            <h2 class="text-2xl font-bold text-white mb-1 group-hover:text-yellow-400 transition-colors">{t.name}</h2>
            <p class="text-gray-400 text-sm italic mb-3">"{t.tagline}"</p>
            <p class="text-xs text-gray-500">{t.period}</p>
            {t.regions.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {t.regions.map(r => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 text-gray-400">{r}</span>
                ))}
              </div>
            )}
          </div>
          <div class="flex md:flex-col gap-6 md:gap-3 md:items-end text-right shrink-0">
            <div>
              <div class="text-2xl font-bold text-white">{t.gross}</div>
              <div class="text-xs text-gray-500">Gross revenue</div>
            </div>
            {t.shows && (
              <div>
                <div class="text-xl font-bold text-white">{t.shows}</div>
                <div class="text-xs text-gray-500">Shows</div>
              </div>
            )}
            <div>
              <div class="text-xl font-bold text-white">{t.songsPerNight}</div>
              <div class="text-xs text-gray-500">Songs/night</div>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="border rounded-xl p-6" style="border-color:#2a2a2a;background-color:#141414">
    <h3 class="text-sm font-semibold text-white mb-4">Tour Operations</h3>
    <div class="grid md:grid-cols-2 gap-4 text-sm">
      <div>
        <div class="text-xs text-gray-500 mb-1">Regional Partners</div>
        <ul class="space-y-1 text-xs text-gray-400">
          <li>Dream Maker — Korea</li>
          <li>Kyodo — Japan</li>
          <li>Live Nation — Asia/US</li>
          <li>AEG — Europe</li>
        </ul>
      </div>
      <div>
        <div class="text-xs text-gray-500 mb-1">Production Cost Breakdown</div>
        <ul class="space-y-1 text-xs text-gray-400">
          <li>Staging: 18–22% of gross</li>
          <li>Freight: 10–14%</li>
          <li>Venue: 12–18%</li>
          <li>Crew: 8–12%</li>
        </ul>
      </div>
    </div>
  </div>
</WikiLayout>
