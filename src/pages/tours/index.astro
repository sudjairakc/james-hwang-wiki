---
import WikiLayout from '../../layouts/WikiLayout.astro';
const base = import.meta.env.BASE_URL;

const tours = [
  {
    slug: 'pulse',
    name: 'PULSE World Tour',
    order: '1st World Tour',
    tagline: 'Let your PULSE rise, come fly with me.',
    period: 'July 28, 2023 – May 30, 2024',
    legs: 4,
    shows: 64,
    cities: 34,
    songsPerNight: '23–33',
    runtime: '1h 42m – 2h 26m',
    ticketGross: '$235M',
    sponsorRev: '$26M',
    profitPool: '$105M',
    color: '#5a7c6a',
    regions: ['East Asia', 'Southeast Asia', 'Oceania', 'Middle East', 'Americas', 'Europe'],
  },
  {
    slug: 'decade',
    name: 'DECADE Tour',
    order: '2nd Tour · Anthology',
    tagline: 'A DECADE lives in songs we made.',
    period: 'January 15 – February 18, 2027',
    legs: 2,
    shows: 18,
    cities: 10,
    songsPerNight: '29',
    runtime: '2h 00m',
    ticketGross: '$74M',
    sponsorRev: '$14M',
    profitPool: '$40M',
    color: '#6e5a7c',
    regions: ['Asia', 'Americas', 'Europe'],
  },
];

const toursChart = {
  metrics: [
    { label: 'Ticket Gross ($M)', values: [235, 74] },
    { label: 'Profit Pool ($M)',  values: [105, 40] },
    { label: 'Shows',            values: [64,  18] },
  ],
  costs: [
    { item: 'Staging / LED',     mid: 20 },
    { item: 'Venue',             mid: 15 },
    { item: 'Freight',           mid: 12 },
    { item: 'Crew payroll',      mid: 10 },
    { item: 'Travel',            mid:  7 },
    { item: 'Insurance',         mid:  3 },
    { item: 'Rehearsals',        mid:  2.5 },
  ],
};

const partners = [
  { region: 'Korea', name: 'Dream Maker' },
  { region: 'Japan', name: 'Kyodo' },
  { region: 'Southeast Asia', name: 'Live Nation Asia' },
  { region: 'North America', name: 'Live Nation' },
  { region: 'Europe', name: 'AEG Presents' },
];

const productionCosts = [
  { item: 'Staging / LED / automation', pct: '18–22%' },
  { item: 'Venue cost', pct: '12–18%' },
  { item: 'Freight & logistics', pct: '10–14%' },
  { item: 'Crew payroll', pct: '8–12%' },
  { item: 'Travel & accommodation', pct: '6–8%' },
  { item: 'Insurance', pct: '2–4%' },
  { item: 'Rehearsals', pct: '2–3%' },
];
---

<WikiLayout title="Tours" section="Live" relatedPages={[
  { label: 'PULSE World Tour', href: `${base}tours/pulse` },
  { label: 'DECADE Tour', href: `${base}tours/decade` },
  { label: 'Discography', href: `${base}discography` },
  { label: 'Awards', href: `${base}awards` },
  { label: 'Career Timeline', href: `${base}timeline` },
]}>
  <div class="mb-8">
    <div class="wiki-label mb-2">Live</div>
    <h1 class="wiki-title mb-2">Tours</h1>
    <p class="text-sm" style="color:var(--text-muted)">$309M combined gross · 82 shows · 44 cities · 2 world tours</p>
  </div>

  <!-- Combined stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
    {[
      { val: '$309M', label: 'Combined Ticket Gross' },
      { val: '$40M', label: 'Combined Sponsor Revenue' },
      { val: '~$145M', label: 'Combined Profit Pool' },
      { val: '~$61M', label: "James' Personal Income" },
    ].map(s => (
      <div class="stat-card">
        <div class="stat-val">{s.val}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Tour cards -->
  <div class="flex flex-col gap-5 mb-10">
    {tours.map(t => (
      <a href={`${base}tours/${t.slug}`}
        class="block border rounded-xl overflow-hidden transition-all group"
        style="border-color:var(--border);background-color:var(--bg-surface);text-decoration:none">

        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-3 border-b" style={`border-color:${t.color}44;background-color:${t.color}10`}>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest mb-0.5" style={`color:${t.color}`}>{t.order}</div>
            <h2 id={t.slug} class="text-xl font-black m-0 group-hover:underline" style={`color:var(--text);text-decoration-color:${t.color}`}>{t.name}</h2>
            <div class="text-xs italic mt-0.5" style="color:var(--text-muted)">"{t.tagline}"</div>
          </div>
          <div class="text-gray-600 group-hover:text-gray-400 transition-colors text-lg">→</div>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-3 md:grid-cols-6 divide-x" style="divide-color:var(--border);border-bottom:1px solid var(--border)">
          {[
            { val: t.shows ?? '—', label: 'Shows' },
            { val: t.cities, label: 'Cities' },
            { val: t.legs, label: 'Legs' },
            { val: t.ticketGross, label: 'Ticket Gross' },
            { val: t.sponsorRev, label: 'Sponsors' },
            { val: t.profitPool, label: 'Profit Pool' },
          ].map(s => (
            <div class="flex flex-col items-center py-3 px-2">
              <div class="text-sm font-bold">{s.val}</div>
              <div class="text-xs" style="color:var(--text-muted)">{s.label}</div>
            </div>
          ))}
        </div>

        <!-- Period + regions -->
        <div class="flex flex-wrap items-center gap-3 px-5 py-2.5">
          <span class="text-xs font-mono" style="color:var(--text-muted)">{t.period}</span>
          <span class="text-xs" style="color:color-mix(in srgb, var(--border) 80%, transparent)">·</span>
          <div class="flex flex-wrap gap-1.5">
            {t.regions.map(r => (
              <span class="text-xs px-2 py-0.5 rounded" style="background-color:var(--bg-muted);color:var(--text-muted)">{r}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Tours chart -->
  <section class="mb-10">
    <div class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--gold)">Tour Comparison</div>
    <p class="text-xs mb-3" style="color:var(--text-faint)">PULSE vs DECADE — metrics & production cost breakdown</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="rounded-xl border overflow-hidden p-4" style="border-color:var(--border);background-color:var(--bg-surface)">
        <div class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:var(--text-muted)">Key Metrics</div>
        <canvas id="tourMetricsChart" height="160" style="width:100%;display:block"></canvas>
        <div class="flex gap-4 mt-3">
          {tours.map(t => (
            <div class="flex items-center gap-2">
              <span class="inline-block w-3 h-3 rounded-sm" style={`background-color:${t.color}`}></span>
              <span class="text-xs font-semibold" style={`color:${t.color}`}>{t.name}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="rounded-xl border overflow-hidden p-4" style="border-color:var(--border);background-color:var(--bg-surface)">
        <div class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:var(--text-muted)">Production Cost Breakdown <span class="font-normal normal-case" style="color:var(--text-faint)">% of gross</span></div>
        <canvas id="tourCostChart" height="160" style="width:100%;display:block"></canvas>
      </div>
    </div>
  </section>

  <!-- Operations -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Partners -->
    <div class="rounded-lg border overflow-hidden" style="border-color:var(--border)">
      <div class="px-4 py-2.5 border-b text-xs font-semibold uppercase tracking-widest" style="border-color:var(--border);background-color:var(--bg-surface);color:var(--gold)">Regional Partners</div>
      {partners.map((p, i, arr) => (
        <div class="flex items-center gap-4 px-4 py-2.5" style={`background-color:var(--bg-surface);${i < arr.length - 1 ? 'border-bottom:1px solid color-mix(in srgb, var(--border) 50%, transparent)' : ''}`}>
          <span class="text-xs font-semibold w-28 shrink-0" style="color:var(--text-muted)">{p.region}</span>
          <span class="text-sm font-medium">{p.name}</span>
        </div>
      ))}
    </div>

    <!-- Production cost breakdown -->
    <div class="rounded-lg border overflow-hidden" style="border-color:var(--border)">
      <div class="px-4 py-2.5 border-b text-xs font-semibold uppercase tracking-widest" style="border-color:var(--border);background-color:var(--bg-surface);color:var(--gold)">
        Production Cost Breakdown <span class="font-normal normal-case" style="color:var(--text-muted)">~55–65% of gross</span>
      </div>
      {productionCosts.map((c, i, arr) => (
        <div class="flex items-center gap-4 px-4 py-2" style={`background-color:var(--bg-surface);${i < arr.length - 1 ? 'border-bottom:1px solid color-mix(in srgb, var(--border) 50%, transparent)' : ''}`}>
          <span class="text-sm flex-1" style="color:var(--text-muted)">{c.item}</span>
          <span class="text-xs font-semibold" style="color:var(--gold)">{c.pct}</span>
        </div>
      ))}
    </div>
  </div>
</WikiLayout>

<script is:inline define:vars={{ toursChart, tours }}>
(function () {
  const cs = getComputedStyle(document.documentElement);
  const gold      = cs.getPropertyValue('--gold').trim()       || '#c9a84c';
  const textFaint = cs.getPropertyValue('--text-faint').trim() || 'rgba(255,255,255,0.25)';
  const borderCol = cs.getPropertyValue('--border').trim()     || 'rgba(255,255,255,0.1)';
  function initCanvas(id, h) {
    const c = document.getElementById(id);
    if (!c) return null;
    const W = c.parentElement.clientWidth - 32;
    const dpr = window.devicePixelRatio || 1;
    c.width = W * dpr; c.height = h * dpr;
    c.style.width = W + 'px'; c.style.height = h + 'px';
    const ctx = c.getContext('2d');
    ctx.scale(dpr, dpr);
    return { ctx, W, H: h };
  }

  // ── Grouped bar: key metrics ──
  const m = initCanvas('tourMetricsChart', 160);
  if (m) {
    const { ctx, W, H } = m;
    const PAD = { l: 90, r: 12, t: 12, b: 24 };
    const cw = W - PAD.l - PAD.r;
    const ch = H - PAD.t - PAD.b;
    const { metrics } = toursChart;
    const colors = tours.map(t => t.color);

    const N = metrics.length;
    const slotH = ch / N;
    const barH = slotH * 0.28;
    const gap = barH * 0.4;

    metrics.forEach((metric, mi) => {
      const maxVal = Math.max(...metric.values) * 1.15;
      const slotTop = PAD.t + mi * slotH;
      const midY = slotTop + slotH / 2;

      // label
      ctx.font = '600 10px system-ui,sans-serif';
      ctx.fillStyle = textFaint;
      ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      ctx.fillText(metric.label, PAD.l - 8, midY);

      metric.values.forEach((val, vi) => {
        const barY = midY + (vi - 0.5) * (barH + gap);
        const bw = (val / maxVal) * cw;
        ctx.fillStyle = colors[vi] + 'cc';
        ctx.beginPath();
        ctx.roundRect(PAD.l, barY, bw, barH, [0, 3, 3, 0]);
        ctx.fill();
        // value
        ctx.font = '700 9px system-ui,sans-serif';
        ctx.fillStyle = colors[vi];
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText(val, PAD.l + bw + 4, barY + barH / 2);
      });

      // row divider
      if (mi < N - 1) {
        ctx.strokeStyle = borderCol; ctx.lineWidth = 1; ctx.setLineDash([2, 3]);
        ctx.beginPath(); ctx.moveTo(PAD.l, slotTop + slotH); ctx.lineTo(W - PAD.r, slotTop + slotH); ctx.stroke();
        ctx.setLineDash([]);
      }
    });
  }

  // ── Horizontal bars: production cost ──
  const c2 = initCanvas('tourCostChart', 160);
  if (c2) {
    const { ctx, W, H } = c2;
    const PAD = { l: 94, r: 40, t: 8, b: 8 };
    const cw = W - PAD.l - PAD.r;
    const ch = H - PAD.t - PAD.b;
    const { costs } = toursChart;
    const maxMid = Math.max(...costs.map(c => c.mid));
    const rowH = ch / costs.length;

    costs.forEach((cost, i) => {
      const y = PAD.t + i * rowH;
      const barY = y + rowH * 0.2;
      const barH = rowH * 0.55;
      const bw = (cost.mid / maxMid) * cw;

      // fill bar with gradient intensity by value
      const alpha = Math.round(80 + (cost.mid / maxMid) * 100).toString(16).padStart(2, '0');
      ctx.fillStyle = gold + alpha;
      ctx.beginPath(); ctx.roundRect(PAD.l, barY, bw, barH, [0, 3, 3, 0]); ctx.fill();

      // label
      ctx.font = '600 9px system-ui,sans-serif';
      ctx.fillStyle = textFaint; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      ctx.fillText(cost.item, PAD.l - 6, y + rowH / 2);

      // pct
      ctx.font = '700 9px system-ui,sans-serif';
      ctx.fillStyle = gold; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('~' + cost.mid + '%', PAD.l + bw + 4, y + rowH / 2);
    });
  }
})();
</script>
