---
import WikiLayout from '../layouts/WikiLayout.astro';
const base = import.meta.env.BASE_URL;
---
<WikiLayout title="404 — Page Not Found" section="Error">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="text-8xl font-black mb-4" style="color:var(--gold);opacity:0.3">404</div>
    <h1 class="wiki-title mb-3">Page Not Found</h1>
    <p class="text-sm mb-8 max-w-md" style="color:var(--text-muted)">
      This page doesn't exist in the JamesHwangVerse — or it may have moved. Try navigating from the sidebar.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href={base} class="px-4 py-2 rounded-lg text-sm font-semibold transition-colors" style="background-color:color-mix(in srgb,var(--gold) 15%,transparent);color:var(--gold)">
        ← Overview
      </a>
      <a href={`${base}timeline`} class="px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="background-color:var(--bg-surface);color:var(--text-muted);border:1px solid var(--border)">
        Career Timeline
      </a>
      <a href={`${base}discography`} class="px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="background-color:var(--bg-surface);color:var(--text-muted);border:1px solid var(--border)">
        Discography
      </a>
      <a href={`${base}filmography`} class="px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="background-color:var(--bg-surface);color:var(--text-muted);border:1px solid var(--border)">
        Filmography
      </a>
    </div>
  </div>
</WikiLayout>
