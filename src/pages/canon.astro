        <div class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:var(--text-muted)">98-Liner Friends</div>
        <div class="flex flex-wrap gap-2">
          {liner98.map(f => (
            <div class="px-3 py-2 rounded-lg border text-center min-w-20" style="border-color:var(--border);background-color:var(--bg-surface)">
              <div class="text-sm font-bold">{f.name}</div>
              <div class="text-xs" style="color:var(--text-muted)">{f.group}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</WikiLayout>

<script is:inline define:vars={{ rangeChart }}>
(function () {
  const canvas = document.getElementById('rangeChart');
  if (!canvas) return;

  // Size canvas to its CSS width
  const cssW = canvas.parentElement.clientWidth - 32; // subtract padding
  const cssH = 160;
  const dpr = window.devicePixelRatio || 1;
  canvas.width = cssW * dpr;
  canvas.height = cssH * dpr;
  canvas.style.width = cssW + 'px';
  canvas.style.height = cssH + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  const W = cssW, H = cssH;
  const PAD_L = 130, PAD_R = 16, PAD_T = 28, PAD_B = 28;
  const chartW = W - PAD_L - PAD_R;
  const { scaleMin, scaleMax, groups } = rangeChart;
  const span = scaleMax - scaleMin;
  const noteX = midi => PAD_L + (midi - scaleMin) / span * chartW;

  const cssStyle = getComputedStyle(document.documentElement);
  const textMuted = cssStyle.getPropertyValue('--text-muted').trim() || 'rgba(255,255,255,0.5)';
  const textFaint = cssStyle.getPropertyValue('--text-faint').trim() || 'rgba(255,255,255,0.3)';
  const borderCol = cssStyle.getPropertyValue('--border').trim() || 'rgba(255,255,255,0.1)';

  // note name helper
  const NOTE_NAMES = ['C','C#','D','Eb','E','F','F#','G','Ab','A','Bb','B'];
  const noteName = midi => NOTE_NAMES[midi % 12] + Math.floor(midi / 12 - 1);

  // vertical grid lines at every C (octave boundary)
  ctx.font = '10px system-ui,sans-serif';
  ctx.textAlign = 'center';
  for (let midi = scaleMin; midi <= scaleMax; midi++) {
    if (midi % 12 === 0) { // C notes
      const x = noteX(midi);
      ctx.beginPath(); ctx.moveTo(x, PAD_T - 12); ctx.lineTo(x, H - PAD_B);
      ctx.strokeStyle = borderCol; ctx.lineWidth = 1; ctx.setLineDash([2, 3]); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = textFaint;
      ctx.fillText(noteName(midi), x, PAD_T - 16);
    }
  }

  // row layout: 3 groups, each occupying a vertical band
  const groupH = (H - PAD_T - PAD_B) / groups.length;
  const BAR_H = 10;
  const FALSETTO_H = 8;
  const CORE_H = 4;

  groups.forEach((grp, gi) => {
    const rowMid = PAD_T + gi * groupH + groupH / 2;

    // group label
    ctx.font = '600 11px system-ui,sans-serif';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = grp.color;
    ctx.fillText(grp.label, PAD_L - 8, rowMid);

    grp.rows.forEach(row => {
      const x1 = noteX(row.lo), x2 = noteX(row.hi);
      const w = Math.max(x2 - x1, 2);

      if (row.type === 'Chest') {
        const y = rowMid - BAR_H / 2;
        ctx.fillStyle = grp.color + '40';
        ctx.strokeStyle = grp.color;
        ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.roundRect(x1, y, w, BAR_H, 3); ctx.fill(); ctx.stroke();
        // note labels at edges
        ctx.font = '9px system-ui,sans-serif';
        ctx.textAlign = 'center'; ctx.fillStyle = grp.color;
        ctx.fillText(noteName(row.lo), x1, rowMid + BAR_H / 2 + 9);
        ctx.fillText(noteName(row.hi), x2, rowMid + BAR_H / 2 + 9);
      } else if (row.type === 'Falsetto') {
        const y = rowMid - BAR_H / 2 - FALSETTO_H - 2;
        ctx.fillStyle = grp.color + '25';
        ctx.strokeStyle = grp.color + 'aa';
        ctx.lineWidth = 1; ctx.setLineDash([3, 2]);
        ctx.beginPath(); ctx.roundRect(x1, y, w, FALSETTO_H, 2); ctx.fill(); ctx.stroke();
        ctx.setLineDash([]);
        ctx.font = '9px system-ui,sans-serif';
        ctx.textAlign = 'center'; ctx.fillStyle = grp.color + 'cc';
        ctx.fillText(noteName(row.hi), x2, y - 3);
      } else if (row.type === 'Power Core') {
        const y = rowMid + BAR_H / 2 + 3;
        ctx.fillStyle = grp.color + '55';
        ctx.beginPath(); ctx.roundRect(x1, y, w, CORE_H, 2); ctx.fill();
      }
    });
  });
})();
</script>

<script is:inline define:vars={{ radarSkills, subRadars, danceRadar, prodRadar, personalityRadar }}>
(function () {
  const cssStyle = getComputedStyle(document.documentElement);
  const cssVar = v => cssStyle.getPropertyValue(v).trim();
  const border = cssVar('--border') || 'rgba(255,255,255,0.12)';
  const textMuted = cssVar('--text-muted') || 'rgba(255,255,255,0.5)';

  // datasets: array of { scores: number[], color, fill, lineWidth, dash }
  function drawRadar(canvasEl, labels, datasets, size, R) {
    const ctx = canvasEl.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    canvasEl.width = size * dpr;
    canvasEl.height = size * dpr;
    canvasEl.style.width = size + 'px';
    canvasEl.style.height = size + 'px';
    ctx.scale(dpr, dpr);

    const cx = size / 2, cy = size / 2;
    const N = labels.length;
    const angle = i => (2 * Math.PI / N) * i - Math.PI / 2;
    const pt = (i, r) => [cx + r * Math.cos(angle(i)), cy + r * Math.sin(angle(i))];

    // grid rings
    [0.25, 0.5, 0.75, 1].forEach(frac => {
      ctx.beginPath();
      for (let i = 0; i < N; i++) {
        const [x, y] = pt(i, R * frac);
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = frac === 1 ? 'rgba(255,255,255,0.15)' : border;
      ctx.lineWidth = 1; ctx.setLineDash([]);
      ctx.stroke();
    });

    // spokes
    for (let i = 0; i < N; i++) {
      const [x, y] = pt(i, R);
      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(x, y);
      ctx.strokeStyle = border; ctx.lineWidth = 1; ctx.setLineDash([]); ctx.stroke();
    }

    // draw each dataset back-to-front (global → idol → james)
    datasets.forEach(ds => {
      ctx.setLineDash(ds.dash || []);
      ctx.beginPath();
      ds.scores.forEach((score, i) => {
        const [x, y] = pt(i, R * (score / 10));
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      });
      ctx.closePath();
      if (ds.fill) { ctx.fillStyle = ds.fill; ctx.fill(); }
      ctx.strokeStyle = ds.color; ctx.lineWidth = ds.lineWidth || 1.5; ctx.stroke();
      ctx.setLineDash([]);

      // dots only for james (last dataset)
      if (ds.dots) {
        ds.scores.forEach((score, i) => {
          const [x, y] = pt(i, R * (score / 10));
          ctx.beginPath(); ctx.arc(x, y, 3, 0, 2 * Math.PI);
          ctx.fillStyle = ds.color; ctx.fill();
        });
      }
    });

    // labels
    ctx.font = (size >= 300 ? '600 11px' : '600 10px') + ' system-ui,sans-serif';
    ctx.fillStyle = textMuted; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    const labelR = R + (size >= 300 ? 22 : 18);
    labels.forEach((name, i) => {
      const [x, y] = pt(i, labelR);
      const lines = name.split('/');
      lines.forEach((line, li) => {
        ctx.fillText(line.trim(), x, y + (li - (lines.length - 1) / 2) * 12);
      });
    });
  }

  const gold = cssVar('--gold') || '#c9a84c';
  const IDOL_COLOR = '#60a5fa';
  const GLOBAL_COLOR = '#6b7280';

  // main overview chart
  const main = document.getElementById('radarChart');
  if (main) {
    const labels = radarSkills.map(s => s.name);
    drawRadar(main, labels, [
      { scores: radarSkills.map(s => s.global), color: GLOBAL_COLOR, lineWidth: 1, dash: [3, 3] },
      { scores: radarSkills.map(s => s.idol),   color: IDOL_COLOR,   lineWidth: 1.5, dash: [5, 3] },
      { scores: radarSkills.map(s => s.james),  color: gold, fill: gold + '28', lineWidth: 2, dots: true },
    ], 320, 128);
  }

  // dance compare radar (3 dancers)
  const danceEl = document.getElementById('danceRadarChart');
  if (danceEl) {
    drawRadar(danceEl, danceRadar.axes, danceRadar.dancers.map((d, idx) => ({
      scores: d.scores,
      color: d.color,
      fill: idx === danceRadar.dancers.length - 1 ? d.color + '20' : null,
      lineWidth: idx === danceRadar.dancers.length - 1 ? 2 : 1.5,
      dash: idx === 0 ? [4, 3] : idx === 1 ? [6, 3] : [],
      dots: idx === danceRadar.dancers.length - 1,
    })), 260, 96);
  }

  // production DNA radar (2 datasets)
  const prodEl = document.getElementById('prodRadarChart');
  if (prodEl) {
    drawRadar(prodEl, prodRadar.axes, prodRadar.datasets.map((d, idx) => ({
      scores: d.scores,
      color: d.color,
      fill: idx === prodRadar.datasets.length - 1 ? d.color + '20' : null,
      lineWidth: idx === prodRadar.datasets.length - 1 ? 2 : 1.5,
      dash: idx === 0 ? [5, 3] : [],
      dots: idx === prodRadar.datasets.length - 1,
    })), 260, 96);
  }

  // sub-skill charts
  subRadars.forEach(sr => {
    const el = document.getElementById(sr.id);
    if (!el) return;
    const labels = sr.skills.map(s => s.name);
    drawRadar(el, labels, [
      { scores: sr.skills.map(s => s.global), color: GLOBAL_COLOR, lineWidth: 1, dash: [3, 3] },
      { scores: sr.skills.map(s => s.idol),   color: IDOL_COLOR,   lineWidth: 1.5, dash: [5, 3] },
      { scores: sr.skills.map(s => s.james),  color: sr.color, fill: sr.color + '28', lineWidth: 2, dots: true },
    ], 220, 82);
  });

  // personality radar
  const persEl = document.getElementById('personalityRadarChart');
  if (persEl) {
    drawRadar(persEl, personalityRadar.axes, [
      { scores: personalityRadar.idolAvg, color: IDOL_COLOR, lineWidth: 1.5, dash: [5, 3] },
      { scores: personalityRadar.scores,  color: gold, fill: gold + '28', lineWidth: 2, dots: true },
    ], 240, 88);
  }

  // ── vibrato waveform ──
  const vibratoEl = document.getElementById('vibratoWave');
  if (vibratoEl) {
    const cssW = vibratoEl.parentElement.clientWidth - 32;
    const cssH = 70;
    const dpr = window.devicePixelRatio || 1;
    vibratoEl.width = cssW * dpr; vibratoEl.height = cssH * dpr;
    vibratoEl.style.width = cssW + 'px'; vibratoEl.style.height = cssH + 'px';
    const vc = vibratoEl.getContext('2d');
    vc.scale(dpr, dpr);
    const VW = cssW, VH = cssH, vmid = VH / 2;
    const breakX = VW * 0.55;
    const vborder = border;

    // center guide
    vc.beginPath(); vc.moveTo(0, vmid); vc.lineTo(VW, vmid);
    vc.strokeStyle = vborder; vc.lineWidth = 1; vc.setLineDash([2, 4]); vc.stroke(); vc.setLineDash([]);

    // waveform
    vc.beginPath(); vc.strokeStyle = gold; vc.lineWidth = 2;
    vc.moveTo(0, vmid);
    vc.lineTo(breakX, vmid);
    const vibratoSpan = VW - breakX;
    for (let x = 0; x <= vibratoSpan; x++) {
      const t = x / vibratoSpan;
      const amp = Math.min(t / 0.25, 1) * 9;
      vc.lineTo(breakX + x, vmid + amp * Math.sin(t * 3.5 * 2 * Math.PI));
    }
    vc.stroke();

    // break line
    vc.beginPath(); vc.moveTo(breakX, 10); vc.lineTo(breakX, VH - 10);
    vc.strokeStyle = gold + '55'; vc.lineWidth = 1; vc.setLineDash([3, 3]); vc.stroke(); vc.setLineDash([]);

    // labels
    vc.font = '10px system-ui,sans-serif'; vc.fillStyle = cssVar('--text-muted') || '#888';
    vc.textAlign = 'center';
    vc.fillText('straight tone', breakX * 0.5, vmid - 13);
    vc.fillText('delayed vibrato', breakX + vibratoSpan * 0.5, vmid - 15);
    vc.font = '9px system-ui,sans-serif';
    vc.textAlign = 'left';  vc.fillText('note start', 4, VH - 4);
    vc.textAlign = 'right'; vc.fillText('note end', VW - 4, VH - 4);
  }

  // ── dynamic range bar ──
  const dynEl = document.getElementById('dynamicRange');
  if (dynEl) {
    const cssW = dynEl.parentElement.clientWidth - 32;
    const cssH = 56;
    const dpr = window.devicePixelRatio || 1;
    dynEl.width = cssW * dpr; dynEl.height = cssH * dpr;
    dynEl.style.width = cssW + 'px'; dynEl.style.height = cssH + 'px';
    const dc = dynEl.getContext('2d');
    dc.scale(dpr, dpr);
    const DW = cssW;
    const PAD = 20, barY = 18, barH = 18, barW = DW - PAD * 2;

    const grad = dc.createLinearGradient(PAD, 0, PAD + barW, 0);
    grad.addColorStop(0,   '#2a3a5a'); grad.addColorStop(0.4, '#3a5a4a');
    grad.addColorStop(0.7, '#6a4a2a'); grad.addColorStop(1,   '#8a2a2a');
    dc.fillStyle = grad;
    dc.beginPath(); dc.roundRect(PAD, barY, barW, barH, 4); dc.fill();

    // comfort zone mp→mf (40%–70%)
    const cx = PAD + barW * 0.40, cw = barW * 0.30;
    dc.fillStyle = gold + '55'; dc.strokeStyle = gold; dc.lineWidth = 1.5;
    dc.beginPath(); dc.roundRect(cx, barY, cw, barH, 3); dc.fill(); dc.stroke();

    const zones = [
      { label: 'pp', p: 0.10 }, { label: 'p', p: 0.30 }, { label: 'mp', p: 0.475 },
      { label: 'mf', p: 0.625 }, { label: 'f', p: 0.775 }, { label: 'ff', p: 0.925 },
    ];
    zones.forEach(z => {
      const comfort = z.label === 'mp' || z.label === 'mf';
      dc.font = comfort ? 'bold 10px system-ui,sans-serif' : '10px system-ui,sans-serif';
      dc.fillStyle = comfort ? gold : (cssVar('--text-muted') || '#888');
      dc.textAlign = 'center'; dc.textBaseline = 'middle';
      dc.fillText(z.label, PAD + barW * z.p, barY + barH / 2);
    });

    dc.font = '9px system-ui,sans-serif'; dc.fillStyle = gold;
    dc.textAlign = 'center'; dc.textBaseline = 'top';
    dc.fillText('comfort zone', cx + cw / 2, barY + barH + 4);
    dc.fillStyle = cssVar('--text-faint') || '#555';
    dc.textAlign = 'left';  dc.fillText('softest', PAD, barY + barH + 4);
    dc.textAlign = 'right'; dc.fillText('loudest', DW - PAD, barY + barH + 4);
  }

  // ── timing pocket diagram ──
  const timingEl = document.getElementById('timingDiagram');
  if (timingEl) {
    const cssW = timingEl.parentElement.clientWidth - 32;
    const cssH = 88;
    const dpr = window.devicePixelRatio || 1;
    timingEl.width = cssW * dpr; timingEl.height = cssH * dpr;
    timingEl.style.width = cssW + 'px'; timingEl.style.height = cssH + 'px';
    const tc = timingEl.getContext('2d');
    tc.scale(dpr, dpr);
    const TW = cssW, TH = cssH;
    const PAD_L = 68, PAD_R = 16;
    const bW = (TW - PAD_L - PAD_R) / 4;
    const rows = [
      { label: 'Ahead',   y: 24, color: '#60a5fa' },
      { label: 'On Beat', y: 44, color: cssVar('--text-muted') || '#888' },
      { label: 'Pocket',  y: 64, color: gold },
    ];

    tc.font = '10px system-ui,sans-serif'; tc.textAlign = 'right'; tc.textBaseline = 'middle';
    rows.forEach(r => {
      tc.beginPath(); tc.moveTo(PAD_L, r.y); tc.lineTo(TW - PAD_R, r.y);
      tc.strokeStyle = border; tc.lineWidth = 1; tc.setLineDash([2, 4]); tc.stroke(); tc.setLineDash([]);
      tc.fillStyle = r.color; tc.fillText(r.label, PAD_L - 6, r.y);
    });

    for (let b = 0; b < 4; b++) {
      const beatX = PAD_L + b * bW + bW * 0.5;
      tc.beginPath(); tc.moveTo(beatX, 10); tc.lineTo(beatX, TH - 10);
      tc.strokeStyle = border; tc.lineWidth = 1; tc.stroke();
      tc.font = '9px system-ui,sans-serif'; tc.fillStyle = cssVar('--text-faint') || '#555';
      tc.textAlign = 'center'; tc.textBaseline = 'top'; tc.fillText(`beat ${b + 1}`, beatX, 2);

      // ghost on-beat dot
      tc.beginPath(); tc.arc(beatX, rows[1].y, 4, 0, 2 * Math.PI);
      tc.fillStyle = border; tc.fill();
      // James pocket dot (slightly behind)
      tc.beginPath(); tc.arc(beatX + bW * 0.08, rows[2].y, 5, 0, 2 * Math.PI);
      tc.fillStyle = gold; tc.fill();
    }

    // legend
    tc.font = '9px system-ui,sans-serif'; tc.textBaseline = 'bottom';
    tc.fillStyle = gold; tc.textAlign = 'right';
    tc.fillText('● James (pocket)', TW - PAD_R, TH);
    tc.fillStyle = border;
    tc.fillText('○ exact beat  ', TW - PAD_R - 110, TH);
  }
})();
</script>
