---
import WikiLayout from '../layouts/WikiLayout.astro';
import { Content } from '../content/wiki/legal.md';
---
<WikiLayout title="Legal" section="History">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">History</div>
    <h1 class="text-4xl font-bold text-white mb-2">Legal History</h1>
    <p class="text-gray-400 text-sm">SM Entertainment contract dispute 2022–2023 · Settlement & departure</p>
  </div>
  <div class="border rounded-lg px-4 py-3 mb-8 flex items-start gap-3" style="border-color:#7c3a3a;background-color:#1a0f0f">
    <span class="text-yellow-500 text-lg">⚖</span>
    <p class="text-xs text-gray-400 leading-relaxed">
      Contract terminated <strong class="text-white">April 27, 2023</strong>.
      Issues: album quota loopholes, management neglect, discriminatory language toward foreign members.
      Resolved via mutual settlement and apology.
    </p>
  </div>
  <div class="prose prose-invert max-w-none"><Content /></div>
</WikiLayout>
