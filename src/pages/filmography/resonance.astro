---
import WikiLayout from '../../layouts/WikiLayout.astro';
const base = import.meta.env.BASE_URL;

const color = '#3a5a7c';

const entries = [
  {
    slug: 'series-captain-eo-resonance',
    label: 'Series',
    badgeText: 'S',
    title: 'Captain EO: RESONANCE',
    subtitle: 'Disney+ Original Series',
    year: '2026',
    date: 'Dec 4, 2026',
    status: 'upcoming',
    episodes: 6,
    platform: 'Disney+',
    role: 'Creator · Showrunner · Lead (Captain EO)',
    highlight: 'EP1: Dead Frequency · Introduces the Starwave Crew and Melodia Universe',
  },
  {
    slug: 'i-missing-chord',
    label: 'Film I',
    badgeText: 'I',
    title: 'RESONANCE: The Missing Chord',
    subtitle: 'Film I of the RESONANCE Saga',
    year: '2028',
    date: 'Nov 2, 2028',
    status: 'upcoming',
    episodes: null,
    platform: 'Theatrical',
    role: 'Creator · Co-Director · Lead (Captain EO)',
    highlight: 'Feature film debut as director · Saga origin story · ACT 0–III structure',
  },
  {
    slug: 'ii-silent-orchestra',
    label: 'Film II',
    badgeText: 'II',
    title: 'RESONANCE II: The Silent Orchestra',
    subtitle: 'Film II of the RESONANCE Saga',
    year: '2030',
    date: 'December 2030 TBA',
    status: 'upcoming',
    episodes: null,
    platform: 'Theatrical',
    role: 'Creator · Co-Director · Lead (Captain EO)',
    highlight: 'When the music dies, the universe follows · Central conflict escalation',
  },
  {
    slug: 'iii-resonance',
    label: 'Film III',
    badgeText: 'III',
    title: 'RESONANCE III',
    subtitle: 'Film III of the RESONANCE Saga',
    year: '2031',
    date: 'December 2031 TBA',
    status: 'upcoming',
    episodes: null,
    platform: 'Theatrical',
    role: 'Creator · Co-Director · Lead (Captain EO)',
    highlight: 'The final movement · Saga conclusion',
  },
  {
    slug: 'canon',
    label: 'Canon',
    badgeText: '★',
    title: 'World Canon & Characters',
    subtitle: 'RESONANCE Universe Reference',
    year: '',
    date: null,
    status: 'reference',
    episodes: null,
    platform: null,
    role: 'World-building documentation',
    highlight: 'The Starwave Crew · Melodia Universe · Character bios · Lore',
  },
];
---

<WikiLayout title="RESONANCE Franchise" section="Filmography" relatedPages={[
  { label: 'Shang-Chi Trilogy', href: `${base}filmography/shang-chi` },
  { label: 'Filmography', href: `${base}filmography` },
  { label: 'Awards', href: `${base}awards` },
  { label: 'Career Timeline', href: `${base}timeline` },
  { label: 'JH Company', href: `${base}company` },
]}>
  <a href={`${base}filmography`} class="inline-flex items-center gap-1.5 text-xs mb-6 transition-colors" style="color:var(--text-muted)">
    ← Back to Filmography
  </a>

  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style={`color:${color}`}>Disney Partnership · Original Universe</div>
    <h1 class="wiki-title mb-1">Captain EO: RESONANCE</h1>
    <p class="text-sm" style="color:var(--text-muted)">4-film saga + Disney+ series · 2026–2030 · Created by James Hwang</p>
  </div>

  <!-- Summary stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
    {[
      { val: '4', label: 'Films' },
      { val: '1', label: 'Disney+ Series' },
      { val: '2026–2030', label: 'Timeline' },
      { val: 'Disney', label: 'Distributor' },
    ].map(s => (
      <div class="stat-card">
        <div class="stat-val">{s.val}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Entry cards -->
  <div class="flex flex-col gap-4 mb-10">
    {entries.map(e => (
      <a href={`${base}filmography/resonance/${e.slug}`}
        class="block border rounded-xl overflow-hidden transition-all group"
        style="border-color:var(--border);background-color:var(--bg-surface);text-decoration:none">

        <!-- Header bar -->
        <div class="flex items-center justify-between px-5 py-3 border-b" style={`border-color:${color}44;background-color:${color}10`}>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center text-sm font-black shrink-0"
              style={`background-color:${color}25;color:${color};border:1px solid ${color}44`}>
              {e.badgeText}
            </div>
            <div>
              <div class="text-base font-black group-hover:underline leading-tight" style={`text-decoration-color:${color}`}>{e.title}</div>
              <div class="text-xs mt-0.5" style="color:var(--text-muted)">{e.subtitle}</div>
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs px-2 py-0.5 rounded font-semibold" style={`background-color:${color}18;color:${color}`}>{e.label}</span>
            {e.status === 'reference'
              ? <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background-color:#3a3a6a30;color:#8888cc">Reference</span>
              : <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background-color:#6a6a1a30;color:#aaaa3a">Upcoming</span>
            }
            <div class="text-gray-600 group-hover:text-gray-400 transition-colors">→</div>
          </div>
        </div>

        <!-- Stats row -->
        {e.status !== 'reference' && (
          <div class="grid grid-cols-3 md:grid-cols-4 divide-x" style="divide-color:var(--border);border-bottom:1px solid var(--border)">
            {[
              { val: e.date ?? '—', label: 'Release' },
              { val: e.platform ?? '—', label: 'Platform' },
              { val: e.episodes != null ? `${e.episodes} Episodes` : 'Feature Film', label: 'Format' },
              { val: e.year || '—', label: 'Year' },
            ].map(c => (
              <div class="flex flex-col items-center py-2.5 px-2 text-center">
                <div class="text-xs font-bold">{c.val}</div>
                <div class="text-xs" style="color:var(--text-muted)">{c.label}</div>
              </div>
            ))}
          </div>
        )}

        <!-- Detail row -->
        <div class="px-5 py-3 flex flex-col gap-1">
          <div class="text-xs font-semibold" style={`color:${color}`}>{e.role}</div>
          <p class="text-xs leading-relaxed" style="color:var(--text-muted)">{e.highlight}</p>
        </div>
      </a>
    ))}
  </div>

  <!-- Universe context -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="rounded-lg border overflow-hidden" style="border-color:var(--border)">
      <div class="px-4 py-2.5 border-b text-xs font-semibold uppercase tracking-widest" style={`border-color:${color}44;background-color:${color}08;color:${color}`}>James's Creative Role</div>
      <div style="background-color:var(--bg-surface)">
        {[
          { role: 'Creator', detail: 'Conceived the Melodia Universe and all major characters' },
          { role: 'Showrunner', detail: 'Leads writers room for the Disney+ series' },
          { role: 'Co-Director', detail: 'Co-directs all three feature films' },
          { role: 'Lead Actor', detail: 'Plays Captain EO across series + films' },
          { role: 'Composer', detail: 'All original music and score' },
        ].map((r, i, arr) => (
          <div class="flex gap-4 px-4 py-2.5" style={i < arr.length - 1 ? 'border-bottom:1px solid color-mix(in srgb, var(--border) 50%, transparent)' : ''}>
            <div class="text-xs font-bold w-24 shrink-0 mt-0.5" style={`color:${color}`}>{r.role}</div>
            <div class="text-xs leading-relaxed" style="color:var(--text-muted)">{r.detail}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="rounded-lg border overflow-hidden" style="border-color:var(--border)">
      <div class="px-4 py-2.5 border-b text-xs font-semibold uppercase tracking-widest" style={`border-color:${color}44;background-color:${color}08;color:${color}`}>Melodia Universe</div>
      <div style="background-color:var(--bg-surface)">
        {[
          { item: 'Setting', val: 'Intergalactic · Melodia Universe' },
          { item: 'Crew', val: 'Starwave Crew (5 members)' },
          { item: 'Antagonist', val: 'The Silent Orchestra' },
          { item: 'Themes', val: 'Music, identity, cosmic harmony' },
          { item: 'Disney Partnership', val: 'Co-produced with Walt Disney Pictures' },
        ].map((r, i, arr) => (
          <div class="flex gap-4 px-4 py-2.5" style={i < arr.length - 1 ? 'border-bottom:1px solid color-mix(in srgb, var(--border) 50%, transparent)' : ''}>
            <div class="text-xs font-semibold w-32 shrink-0" style="color:var(--text-muted)">{r.item}</div>
            <div class="text-sm">{r.val}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</WikiLayout>
