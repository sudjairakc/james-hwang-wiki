---
import WikiLayout from '../../layouts/WikiLayout.astro';
const base = import.meta.env.BASE_URL;

const color = '#3a5a7c';

const entries = [
  {
    slug: 'series-captain-eo-resonance',
    label: 'Series',
    num: null,
    title: 'Captain EO: RESONANCE',
    year: '2026',
    note: 'Disney+ Original Series · EP1: Dead Frequency',
  },
  {
    slug: 'i-missing-chord',
    label: 'Film I',
    num: 'I',
    title: 'RESONANCE: The Missing Chord',
    year: '2027',
    note: 'Feature Film · The beginning of the saga',
  },
  {
    slug: 'ii-silent-orchestra',
    label: 'Film II',
    num: 'II',
    title: 'RESONANCE II: The Silent Orchestra',
    year: '2029',
    note: 'Feature Film · When the music dies, the universe follows',
  },
  {
    slug: 'iii-resonance',
    label: 'Film III',
    num: 'III',
    title: 'RESONANCE III',
    year: '2030',
    note: 'Feature Film · The final movement',
  },
  {
    slug: 'canon',
    label: 'Canon',
    num: null,
    title: 'World Canon & Characters',
    year: '',
    note: 'The Starwave Crew · Melodia Universe · Character bios',
  },
];
---

<WikiLayout title="RESONANCE Franchise" section="Filmography">
  <a href={`${base}filmography`} class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-gray-300 mb-6 transition-colors">
    ← Back to Filmography
  </a>

  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Disney Partnership</div>
    <h1 class="text-4xl font-bold text-white mb-1">Captain EO: RESONANCE</h1>
    <p class="text-gray-400 text-sm">4-film saga + series · 2026–2030</p>
  </div>

  <div class="space-y-2">
    {entries.map((e) => (
      <a href={`${base}filmography/resonance/${e.slug}`}
        class="flex items-center gap-4 border rounded-xl px-5 py-4 hover:border-gray-500 transition-all group"
        style="border-color:#2a2a2a;background-color:#141414">
        <!-- Number badge -->
        <div class="w-10 h-10 rounded-lg flex items-center justify-center text-sm font-bold shrink-0"
          style={`background-color:${color}22;color:${color};border:1px solid ${color}44`}>
          {e.num ?? e.label.slice(0, 1)}
        </div>
        <!-- Info -->
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-0.5">
            <span class="text-sm font-semibold text-white group-hover:text-yellow-400 transition-colors">{e.title}</span>
            <span class="text-xs px-1.5 py-0.5 rounded font-semibold uppercase tracking-wider"
              style={`background:${color}18;color:${color}`}>{e.label}</span>
          </div>
          <div class="text-xs text-gray-500">{e.note}</div>
        </div>
        <!-- Year -->
        {e.year && <div class="text-sm font-bold text-gray-500 shrink-0">{e.year}</div>}
        <!-- Arrow -->
        <div class="text-gray-700 group-hover:text-gray-400 transition-colors shrink-0">→</div>
      </a>
    ))}
  </div>
</WikiLayout>
