---
import WikiLayout from '../../../layouts/WikiLayout.astro';
const base = import.meta.env.BASE_URL;

const slugMap: Record<string, {
  title: string; subtitle: string; year: string; date: string | null; label: string; color: string; tagline: string;
  format: string; credits: { label: string; val: string }[];
}> = {
  'series-captain-eo-resonance': {
    title: 'Captain EO: RESONANCE',
    subtitle: 'Disney+ Original Series · Season 1',
    year: '2026',
    date: 'Dec 4, 2026',
    label: 'Series',
    color: '#3a5a7c',
    tagline: 'The Starwave crew begins their mission',
    format: '6 Episodes · Disney+ · Weekly rollout (EP1–2 premiere)',
    credits: [
      { label: 'Created by', val: 'James Hwang' },
      { label: 'Showrunner', val: 'Tony Gilroy' },
      { label: 'Directors', val: 'Dan Trachtenberg (EP1–2) · Kogonada (EP3–4) · Jennifer Phang (EP5–6)' },
      { label: 'DoP', val: 'Greig Fraser' },
      { label: 'Composer', val: 'Ludwig Göransson' },
      { label: 'VFX', val: 'Industrial Light & Magic · Framestore · DNEG · Wētā FX' },
      { label: 'Production', val: 'Lucasfilm Ltd. · JH Company' },
      { label: 'Distributor', val: 'Disney+' },
    ],
  },
  'i-missing-chord': {
    title: 'RESONANCE: The Missing Chord',
    subtitle: 'Film I of the RESONANCE Saga',
    year: '2028',
    date: 'Nov 2, 2028',
    label: 'Film I',
    color: '#3a5a7c',
    tagline: 'The beginning of a cosmic journey',
    format: 'Feature Film · Theatrical',
    credits: [
      { label: 'Created by', val: 'James Hwang' },
      { label: 'Director', val: 'James Hwang (Co-Director)' },
      { label: 'Lead', val: 'James Hwang as Captain EO' },
      { label: 'Distributor', val: 'Walt Disney Pictures' },
    ],
  },
  'ii-silent-orchestra': {
    title: 'RESONANCE II: The Silent Orchestra',
    subtitle: 'Film II of the RESONANCE Saga',
    year: '2030',
    date: 'December 2030 TBA',
    label: 'Film II',
    color: '#3a5a7c',
    tagline: 'When the music dies, the universe follows',
    format: 'Feature Film · Theatrical',
    credits: [
      { label: 'Created by', val: 'James Hwang' },
      { label: 'Director', val: 'James Hwang (Co-Director)' },
      { label: 'Lead', val: 'James Hwang as Captain EO' },
      { label: 'Distributor', val: 'Walt Disney Pictures' },
    ],
  },
  'iii-resonance': {
    title: 'RESONANCE III',
    subtitle: 'Film III of the RESONANCE Saga · Final Movement',
    year: '2031',
    date: 'December 2031 TBA',
    label: 'Film III',
    color: '#3a5a7c',
    tagline: 'The final movement',
    format: 'Feature Film · Theatrical',
    credits: [
      { label: 'Created by', val: 'James Hwang' },
      { label: 'Director', val: 'James Hwang (Co-Director)' },
      { label: 'Lead', val: 'James Hwang as Captain EO' },
      { label: 'Distributor', val: 'Walt Disney Pictures' },
    ],
  },
  'canon': {
    title: 'World Canon & Characters',
    subtitle: 'RESONANCE Universe Reference',
    year: '',
    date: null,
    label: 'Canon',
    color: '#3a5a7c',
    tagline: 'The Starwave Crew · Melodia Universe · Character bios',
    format: 'Reference document',
    credits: [
      { label: 'Universe', val: 'Melodia Universe' },
      { label: 'Crew', val: 'Starwave Crew (5 members)' },
      { label: 'Created by', val: 'James Hwang' },
    ],
  },
};

export function getStaticPaths() {
  return [
    'series-captain-eo-resonance',
    'i-missing-chord',
    'ii-silent-orchestra',
    'iii-resonance',
    'canon',
  ].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const meta = slugMap[slug];

const modules = import.meta.glob('../../../content/wiki/filmography/resonance/*.md');
const key = `../../../content/wiki/filmography/resonance/${slug}.md`;
const mod = await modules[key]() as { Content: any };
const { Content } = mod;
---

<WikiLayout title={meta.title} section="Filmography">
  <a href={`${base}filmography/resonance`}
    class="inline-flex items-center gap-1.5 text-xs mb-6 transition-colors" style="color:var(--text-muted)">
    ← Back to RESONANCE Franchise
  </a>

  <!-- Header -->
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-1" style={`color:${meta.color}`}>
      Captain EO: RESONANCE · {meta.label}
    </div>
    <h1 class="wiki-title mb-2">{meta.title}</h1>
    <p class="text-sm mb-2" style="color:var(--text-muted)">{meta.subtitle}</p>
    <div class="flex flex-wrap items-center gap-2">
      {meta.date && (
        <span class="text-xs px-2 py-0.5 rounded font-semibold" style={`background-color:${meta.color}18;color:${meta.color}`}>{meta.date}</span>
      )}
      <span class="text-xs px-2 py-0.5 rounded font-semibold" style="background-color:#6a6a1a30;color:#aaaa3a">
        {meta.label === 'Canon' ? 'Reference' : 'Upcoming'}
      </span>
      <span class="text-xs italic" style="color:var(--text-muted)">"{meta.tagline}"</span>
    </div>
  </div>

  <!-- Format + credits -->
  <div class="rounded-lg border overflow-hidden mb-8" style="border-color:var(--border)">
    <div class="px-4 py-2.5 border-b text-xs font-semibold uppercase tracking-widest" style={`border-color:${meta.color}44;background-color:${meta.color}08;color:${meta.color}`}>
      {meta.format}
    </div>
    <div style="background-color:var(--bg-surface)">
      {meta.credits.map((r, i, arr) => (
        <div class="flex gap-4 px-4 py-2.5" style={i < arr.length - 1 ? 'border-bottom:1px solid color-mix(in srgb, var(--border) 50%, transparent)' : ''}>
          <div class="text-xs font-semibold w-28 shrink-0 mt-0.5" style="color:var(--text-muted)">{r.label}</div>
          <div class="text-sm leading-relaxed">{r.val}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Content -->
  <div class="resonance-prose prose prose-invert max-w-none">
    <Content />
  </div>
</WikiLayout>

<style>
  .resonance-prose :global(h1) {
    display: none;
  }
  .resonance-prose :global(h2) {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
  }
  .resonance-prose :global(h3) {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .resonance-prose :global(p) {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }
  .resonance-prose :global(ul), .resonance-prose :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .resonance-prose :global(li) {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.35rem;
  }
  .resonance-prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .resonance-prose :global(em) {
    color: var(--text-muted);
    opacity: 0.85;
  }
  .resonance-prose :global(hr) {
    border-color: color-mix(in srgb, var(--border) 50%, transparent);
    margin: 1.5rem 0;
  }
  /* Hide raw credits block at top of markdown */
  .resonance-prose :global(p:first-child br) {
    display: none;
  }
</style>
