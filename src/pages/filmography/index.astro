---
import WikiLayout from '../../layouts/WikiLayout.astro';

const base = import.meta.env.BASE_URL;

const films = [
  {
    franchise: 'Shang-Chi Trilogy (MCU)',
    color: '#7c5a3a',
    entries: [
      { title: 'Shang-Chi and the Legend of the Ten Rings', year: '2021', status: 'Released' },
      { title: 'Shang-Chi: Legacy of the Ten Rings', year: '2025', status: 'Released' },
      { title: 'Shang-Chi: Legion Accursed', year: '2026', status: 'Upcoming' },
    ],
  },
  {
    franchise: 'Captain EO: RESONANCE Saga (Disney)',
    color: '#3a5a7c',
    entries: [
      { title: 'Captain EO: RESONANCE', year: '2026', status: 'Upcoming' },
      { title: 'RESONANCE: The Missing Chord', year: '2027', status: 'Upcoming' },
      { title: 'RESONANCE II: Silent Orchestra', year: '2029', status: 'Upcoming' },
      { title: 'RESONANCE III', year: '2030', status: 'Upcoming' },
    ],
  },
];
---

<WikiLayout title="Filmography" section="Film & Screen">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Film & Screen</div>
    <h1 class="text-4xl font-bold text-white mb-2">Filmography</h1>
    <p class="text-gray-400 text-sm">MCU + Disney franchise · 6 films, 1 series across 2 universes</p>
  </div>

  <div class="space-y-8">
    {films.map(f => (
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-6 rounded-full" style={`background-color:${f.color}`}></div>
          <h2 class="text-base font-semibold text-white">{f.franchise}</h2>
        </div>
        <div class="space-y-2">
          {f.entries.map((e, i) => (
            <div class="flex items-center gap-4 border rounded-lg px-5 py-4" style="border-color:#2a2a2a;background-color:#141414">
              <div class="w-8 h-8 rounded-md flex items-center justify-center text-sm font-bold shrink-0"
                style={`background-color:${f.color}25;color:${f.color}`}>
                {i + 1}
              </div>
              <div class="flex-1">
                <div class="text-sm font-semibold text-white">{e.title}</div>
                <div class="text-xs text-gray-500">{e.year}</div>
              </div>
              <span class={`text-xs px-2 py-0.5 rounded-full ${e.status === 'Released' ? 'bg-green-900/40 text-green-400' : 'bg-yellow-900/40 text-yellow-400'}`}>
                {e.status}
              </span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="mt-10 grid md:grid-cols-2 gap-4">
    <a href={`${base}filmography/shang-chi`}
      class="border rounded-xl p-6 hover:border-gray-500 transition-all group"
      style="border-color:#2a2a2a;background-color:#141414">
      <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Deep Dive</div>
      <h3 class="text-lg font-bold text-white mb-2 group-hover:text-yellow-400 transition-colors">Shang-Chi Trilogy</h3>
      <p class="text-xs text-gray-500">Full production notes, character arc, MCU crossover details</p>
    </a>
    <a href={`${base}filmography/resonance`}
      class="border rounded-xl p-6 hover:border-gray-500 transition-all group"
      style="border-color:#2a2a2a;background-color:#141414">
      <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Deep Dive</div>
      <h3 class="text-lg font-bold text-white mb-2 group-hover:text-yellow-400 transition-colors">RESONANCE Franchise</h3>
      <p class="text-xs text-gray-500">Disney partnership · cinematic universe · 4-film saga</p>
    </a>
  </div>
</WikiLayout>
