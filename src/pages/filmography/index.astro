---
import WikiLayout from '../../layouts/WikiLayout.astro';

const base = import.meta.env.BASE_URL;

const franchises = [
  {
    href: `${base}filmography/shang-chi`,
    franchise: 'Shang-Chi Trilogy',
    universe: 'Marvel Cinematic Universe',
    color: '#7c5a3a',
    entries: [
      { title: 'Shang-Chi and the Legend of the Ten Rings', date: 'Sep 3, 2021', status: 'Released', note: 'MCU Phase 4 · James Hwang as Shang-Chi' },
      { title: 'Shang-Chi: Legacy of the Ten Rings', date: 'May 2, 2025', status: 'Released', note: 'MCU Phase 5 · co-wrote screenplay' },
      { title: 'Shang-Chi: Legion Accursed', date: 'May 1, 2026', status: 'Upcoming', note: 'MCU Phase 6 · franchise conclusion' },
    ],
  },
  {
    href: `${base}filmography/resonance`,
    franchise: 'Captain EO: RESONANCE Saga',
    universe: 'Disney · Original Franchise',
    color: '#3a5a7c',
    entries: [
      { title: 'Captain EO: RESONANCE', date: 'Nov 12, 2026', status: 'Upcoming', note: 'Disney+ Original Series · EP1: Dead Frequency' },
      { title: 'RESONANCE: The Missing Chord', date: 'Jul 4, 2027', status: 'Upcoming', note: 'Film I · The beginning of the saga' },
      { title: 'RESONANCE II: Silent Orchestra', date: '2029 TBA', status: 'Upcoming', note: 'Film II · When the music dies, the universe follows' },
      { title: 'RESONANCE III', date: '2030 TBA', status: 'Upcoming', note: 'Film III · The final movement' },
    ],
  },
];
---

<WikiLayout title="Filmography" section="Film & Screen">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:var(--gold)">Film & Screen</div>
    <h1 class="text-4xl font-bold text-white mb-2">Filmography</h1>
    <p class="text-sm" style="color:var(--text-muted)">MCU + Disney franchise · 6 films · 1 series · 2 universes</p>
  </div>

  <div class="flex flex-col gap-6">
    {franchises.map(f => (
      <a href={f.href}
        class="block border rounded-xl overflow-hidden transition-all group"
        style="border-color:var(--border);background-color:var(--bg-surface);text-decoration:none">

        <!-- Franchise header -->
        <div class="flex items-center justify-between px-5 py-3 border-b" style={`border-color:${f.color}44;background-color:${f.color}10`}>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest mb-0.5" style={`color:${f.color}`}>{f.universe}</div>
            <div class="text-base font-black text-white group-hover:underline" style={`text-decoration-color:${f.color}`}>{f.franchise}</div>
          </div>
          <div class="text-gray-600 group-hover:text-gray-400 transition-colors text-lg">→</div>
        </div>

        <!-- Film rows -->
        {f.entries.map((e, i, arr) => (
          <div class="flex items-center gap-4 px-5 py-3"
            style={`${i < arr.length - 1 ? 'border-bottom:1px solid color-mix(in srgb, var(--border) 60%, transparent)' : ''}`}>
            <!-- Index number -->
            <div class="w-6 h-6 rounded flex items-center justify-center text-xs font-bold shrink-0"
              style={`background-color:${f.color}18;color:${f.color}`}>{i + 1}</div>
            <!-- Title + note -->
            <div class="flex-1 min-w-0">
              <div class="text-sm font-semibold text-white truncate">{e.title}</div>
              <div class="text-xs" style="color:var(--text-muted)">{e.note}</div>
            </div>
            <!-- Date + status -->
            <div class="flex items-center gap-2.5 shrink-0">
              <span class="text-xs font-mono font-medium" style="color:var(--text-muted)">{e.date}</span>
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold"
                style={e.status === 'Released'
                  ? 'background-color:color-mix(in srgb,#22c55e 12%,transparent);color:#4ade80'
                  : 'background-color:color-mix(in srgb,#facc15 10%,transparent);color:#facc15'}>
                {e.status}
              </span>
            </div>
          </div>
        ))}
      </a>
    ))}
  </div>
</WikiLayout>
