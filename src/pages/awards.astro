---
import WikiLayout from '../layouts/WikiLayout.astro';
import { Content } from '../content/wiki/awards.md';
---
<WikiLayout title="Awards" section="Recognition">
  <div class="mb-8">
    <div class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#c9a84c">Recognition</div>
    <h1 class="text-4xl font-bold text-white mb-2">Awards</h1>
    <p class="text-gray-400 text-sm">Grammy, Melon, Asia Artist Awards, Seoul Music Awards · 2022–2025</p>
  </div>
  <div class="prose prose-invert max-w-none"><Content /></div>
</WikiLayout>
